Sub t1 r1 r2). Π(env : SemCtx g1). Π(_ : GoodEnv g1 rg1 env). Σ(k : Nat). SemE t1 r2 k (sub_ground g1 t1 e1 env)) fund_lam_case fund_let_case d : Π(g : Ctx). Π(rg : RCtx g). Π(t : Ty). Π(r : RTy t). Π(e : Expr g t). Π(_ : HasR g rg t r e). Π(env : SemCtx g). Π(_ : GoodEnv g rg env). Σ(k : Nat). SemE t r k (sub_ground g t e env))
