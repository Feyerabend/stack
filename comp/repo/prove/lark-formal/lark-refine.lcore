-- ── Smoke tests: the summit computes ──────────────────────────────────────────

-- closed instance: the literal 2 at {ge2}, empty everything
:let d_lit = (RT_Int empty star ge2 n2 star : HasR empty star TInt rge2 (ELitInt empty n2))
:let fund_lit = (fund empty star TInt rge2 (ELitInt empty n2) d_lit star star : Σ(k : Nat). SemE TInt rge2 k (sub_ground empty TInt (ELitInt empty n2) star))
:i fund_lit

-- THE SHOWCASE: f (if true then 2 else 3), with f : {ge2}→{ge2} a HYPOTHESIS
-- (idInt enters through the environment — higher-order USE without RT_Lam).
-- Every rule fires: Var (rlookup computes rid22), Bool, Int (payload evidence
-- by computation), If (J + boolrec select the branch), App (both lifts, the
-- applicative clause, budget arithmetic), and Sub weakens the result to {ge1}.
:let gF = (ext (TFn TInt TInt) empty : Ctx)
:let rgF = ((rid22, star) : RCtx gF)
:let envF = ((idInt, star) : SemCtx gF)
:let geF = ((semv_id, star) : GoodEnv gF rgF envF)
:let vF = (here empty (TFn TInt TInt) : Var gF (TFn TInt TInt))

:let d_f = (RT_Var gF rgF (TFn TInt TInt) vF : HasR gF rgF (TFn TInt TInt) rid22 (EVar gF (TFn TInt TInt) vF))
:let d_arg = (RT_If gF rgF TInt rge2 (ELitBool gF true) (ELitInt gF n2) (ELitInt gF n3) (RT_Bool gF rgF true) (RT_Int gF rgF ge2 n2 star) (RT_Int gF rgF ge2 n3 star) : HasR gF rgF TInt rge2 (EIf gF TInt (ELitBool gF true) (ELitInt gF n2) (ELitInt gF n3)))
:let eF = (EApp gF TInt TInt (EVar gF (TFn TInt TInt) vF) (EIf gF TInt (ELitBool gF true) (ELitInt gF n2) (ELitInt gF n3)) : Expr gF TInt)
:let d_app = (RT_App gF rgF TInt TInt rge2 rge2 (EVar gF (TFn TInt TInt) vF) (EIf gF TInt (ELitBool gF true) (ELitInt gF n2) (ELitInt gF n3)) d_f d_arg : HasR gF rgF TInt rge2 eF)
:let d_sub = (RT_Sub gF rgF TInt rge2 rge1 eF d_app sub21 : HasR gF rgF TInt rge1 eF)

-- run it: the certificate COMPUTES — the condition steps, the argument
-- lands at 2, β fires through the applicative clause, and the payload
-- arrives good at the WEAKENED {ge1}
:let fund_run = (fund gF rgF TInt rge1 eF d_sub envF geF : Σ(k : Nat). SemE TInt rge1 k (sub_ground gF TInt eF envF))
:i fund_run

-- ── Pitch 2 smokes: λ-introduction and let, closed, through fund ───────────────

-- the bound variable, shared by both smokes (rlookup at `here` computes to rge2)
:let idbody = (EVar (ext TInt empty) TInt (here empty TInt) : Expr (ext TInt empty) TInt)
:let d_idvar = (RT_Var (ext TInt empty) (rge2, star) TInt (here empty TInt) : HasR (ext TInt empty) (rge2, star) TInt rge2 idbody)

-- RT_Lam: (λx:{ge2}. x) : {ge2}→{ge2}. fund hands back a value at j=0 whose
-- arrow clause runs the body IH — the certificate COMPUTES to the identity.
:let d_idlam = (RT_Lam empty star TInt TInt rge2 rge2 idbody d_idvar : HasR empty star (TFn TInt TInt) (RFn TInt TInt rge2 rge2) (ELam empty TInt TInt idbody))
:let fund_idlam = (fund empty star (TFn TInt TInt) (RFn TInt TInt rge2 rge2) (ELam empty TInt TInt idbody) d_idlam star star : Σ(k : Nat). SemE (TFn TInt TInt) (RFn TInt TInt rge2 rge2) k (sub_ground empty (TFn TInt TInt) (ELam empty TInt TInt idbody) star))
:i fund_idlam

-- RT_Let: (let x = 2 in x) : {ge2}. the bound val runs to a value (semv_isval),
-- StepLetBeta fires, fuse transports, and the body IH finishes at x ↦ 2.
:let d_let = (RT_Let empty star TInt TInt rge2 rge2 (ELitInt empty n2) idbody d_lit d_idvar : HasR empty star TInt rge2 (ELet empty TInt TInt (ELitInt empty n2) idbody))
:let fund_let = (fund empty star TInt rge2 (ELet empty TInt TInt (ELitInt empty n2) idbody) d_let star star : Σ(k : Nat). SemE TInt rge2 k (sub_ground empty TInt (ELet empty TInt TInt (ELitInt empty n2) idbody) star))
:i fund_let
