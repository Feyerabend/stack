-- ═══════════════════════════════════════════════════════════════════════════
-- strand vdeep — verified elaboration of Lark refinement derivations into an
-- intrinsically-typed MLTT object theory living inside lcore.  C0 scouting probe.
--
-- Loads AFTER the metatheory + lark-refine.lcore (needs Nat, Bool, IsTrue, Ty,
-- Ctx, Var, Expr, RTy, RCtx, HasR, rlookup, here, there, ext, empty, TInt, ...).
--
-- STATUS (2026-07-17):
--   • Block A (object theory + ⟦·⟧ translations + elabVar + the introduction-only
--     elab CASES) — VERIFIED green (piped after meta+refine, 0 errors; tyD /
--     elabVar / elab_lam inferred clean). All 8 HasR rules bar RT_Sub's SubFn are
--     introduction-only and wall-free, exactly as fundD predicted.
--   • Block B (intrinsic renaming: OPE + mweaken) — VERIFIED green. The crux:
--     `mweaken : MTm g t → MTm (mcons s g) t` and `ope_tm` infer their intended
--     types, so `indrec MTm` DOES go under the mlam/mlet binder via `ope_keep`.
--     vdeep does not re-hit the DESCEND wall even at renaming-under-binders.
--     (Fix that landed it: lcore interleaves each recursive arg's IH immediately
--     after it — mapp/mif/mlet cases are `\x. \ihx.` per premise, not bunched.)
--   • NOT YET WRITTEN: elabSub (SubBase = msub_weaken; SubFn = the coercion that
--     USES mweaken), and the full `elab = indrec HasR` assembly tying it together.
-- ═══════════════════════════════════════════════════════════════════════════

-- ── Block A — object theory + translations + intro-only cases (VERIFIED) ──────
data MTy : Type where MNat : MTy ; MBool : MTy ; MSub : Π(_ : Π(_ : Nat). Bool). MTy ; MFun : Π(_ : MTy). Π(_ : MTy). MTy
data MCtx : Type where mnil : MCtx ; mcons : Π(_ : MTy). Π(_ : MCtx). MCtx
data MVar : Π(_ : MCtx). Π(_ : MTy). Type where mhere : Π(g : MCtx). Π(t : MTy). MVar (mcons t g) t ; mthere : Π(g : MCtx). Π(t : MTy). Π(s : MTy). Π(_ : MVar g t). MVar (mcons s g) t
data MTm : Π(_ : MCtx). Π(_ : MTy). Type where mvar : Π(g : MCtx). Π(t : MTy). Π(_ : MVar g t). MTm g t ; msub_intro : Π(g : MCtx). Π(p : Π(_ : Nat). Bool). Π(n : Nat). Π(_ : IsTrue (p n)). MTm g (MSub p) ; mbool_intro : Π(g : MCtx). Π(_ : Bool). MTm g MBool ; mapp : Π(g : MCtx). Π(a : MTy). Π(b : MTy). Π(_ : MTm g (MFun a b)). Π(_ : MTm g a). MTm g b ; mlam : Π(g : MCtx). Π(a : MTy). Π(b : MTy). Π(_ : MTm (mcons a g) b). MTm g (MFun a b) ; mif : Π(g : MCtx). Π(t : MTy). Π(_ : MTm g MBool). Π(_ : MTm g t). Π(_ : MTm g t). MTm g t ; mlet : Π(g : MCtx). Π(a : MTy). Π(b : MTy). Π(_ : MTm g a). Π(_ : MTm (mcons a g) b). MTm g b ; msub_weaken : Π(g : MCtx). Π(p : Π(_ : Nat). Bool). Π(q : Π(_ : Nat). Bool). Π(_ : Π(n : Nat). Π(_ : IsTrue (p n)). IsTrue (q n)). Π(_ : MTm g (MSub p)). MTm g (MSub q)
:let tyD = (\t. \r. indrec RTy (\t1. \r1. MTy : Π(t1 : Ty). Π(r1 : RTy t1). Type) (\p. MSub p : Π(p : Π(_ : Nat). Bool). MTy) (MBool : MTy) (\a. \b. \ra. \iha. \rb. \ihb. MFun iha ihb : Π(a : Ty). Π(b : Ty). Π(ra : RTy a). Π(iha : MTy). Π(rb : RTy b). Π(ihb : MTy). MTy) r : Π(t : Ty). Π(r : RTy t). MTy)
:let ctxD = (\g. indrec Ctx (\g1. Π(_ : RCtx g1). MCtx : Ctx → Type) (\rg. mnil : Π(_ : RCtx empty). MCtx) (\t. \g1. \ih. \rg. mcons (tyD t (fst rg)) (ih (snd rg)) : Π(t : Ty). Π(g1 : Ctx). Π(_ : Π(_ : RCtx g1). MCtx). Π(_ : RCtx (ext t g1)). MCtx) g : Π(g : Ctx). Π(_ : RCtx g). MCtx)
:let elabVar = (\g. \t. \v. indrec Var (\g1. \t1. \v1. Π(rg : RCtx g1). MVar (ctxD g1 rg) (tyD t1 (rlookup g1 t1 v1 rg)) : Π(g1 : Ctx). Π(t1 : Ty). Π(v1 : Var g1 t1). Type) (\g1. \t1. \rg. mhere (ctxD g1 (snd rg)) (tyD t1 (fst rg)) : Π(g1 : Ctx). Π(t1 : Ty). Π(rg : RCtx (ext t1 g1)). MVar (ctxD (ext t1 g1) rg) (tyD t1 (rlookup (ext t1 g1) t1 (here g1 t1) rg))) (\g1. \t1. \s. \v1. \ih. \rg. mthere (ctxD g1 (snd rg)) (tyD t1 (rlookup g1 t1 v1 (snd rg))) (tyD s (fst rg)) (ih (snd rg)) : Π(g1 : Ctx). Π(t1 : Ty). Π(s : Ty). Π(v1 : Var g1 t1). Π(_ : Π(rg : RCtx g1). MVar (ctxD g1 rg) (tyD t1 (rlookup g1 t1 v1 rg))). Π(rg : RCtx (ext s g1)). MVar (ctxD (ext s g1) rg) (tyD t1 (rlookup (ext s g1) t1 (there g1 t1 s v1) rg))) v : Π(g : Ctx). Π(t : Ty). Π(v : Var g t). Π(rg : RCtx g). MVar (ctxD g rg) (tyD t (rlookup g t v rg)))
:let elab_int = (\g1. \rg1. \p. \n. \ev. msub_intro (ctxD g1 rg1) p n ev : Π(g1 : Ctx). Π(rg1 : RCtx g1). Π(p : Π(_ : Nat). Bool). Π(n : Nat). Π(ev : IsTrue (p n)). MTm (ctxD g1 rg1) (tyD TInt (RInt p)))
:let elab_bool = (\g1. \rg1. \b1. mbool_intro (ctxD g1 rg1) b1 : Π(g1 : Ctx). Π(rg1 : RCtx g1). Π(b1 : Bool). MTm (ctxD g1 rg1) (tyD TBool RBool))
:let elab_var = (\g1. \rg1. \t1. \v1. mvar (ctxD g1 rg1) (tyD t1 (rlookup g1 t1 v1 rg1)) (elabVar g1 t1 v1 rg1) : Π(g1 : Ctx). Π(rg1 : RCtx g1). Π(t1 : Ty). Π(v1 : Var g1 t1). MTm (ctxD g1 rg1) (tyD t1 (rlookup g1 t1 v1 rg1)))
:let elab_app = (\g1. \rg1. \a. \b. \ra. \rb. \f. \x. \df. \ihf. \dx. \ihx. mapp (ctxD g1 rg1) (tyD a ra) (tyD b rb) ihf ihx : Π(g1 : Ctx). Π(rg1 : RCtx g1). Π(a : Ty). Π(b : Ty). Π(ra : RTy a). Π(rb : RTy b). Π(f : Expr g1 (TFn a b)). Π(x : Expr g1 a). Π(df : HasR g1 rg1 (TFn a b) (RFn a b ra rb) f). Π(ihf : MTm (ctxD g1 rg1) (tyD (TFn a b) (RFn a b ra rb))). Π(dx : HasR g1 rg1 a ra x). Π(ihx : MTm (ctxD g1 rg1) (tyD a ra)). MTm (ctxD g1 rg1) (tyD b rb))
:let elab_lam = (\g1. \rg1. \a. \b. \ra. \rb. \body. \dbody. \ihbody. mlam (ctxD g1 rg1) (tyD a ra) (tyD b rb) ihbody : Π(g1 : Ctx). Π(rg1 : RCtx g1). Π(a : Ty). Π(b : Ty). Π(ra : RTy a). Π(rb : RTy b). Π(body : Expr (ext a g1) b). Π(dbody : HasR (ext a g1) (ra, rg1) b rb body). Π(ihbody : MTm (ctxD (ext a g1) (ra, rg1)) (tyD b rb)). MTm (ctxD g1 rg1) (tyD (TFn a b) (RFn a b ra rb)))
:let elab_let = (\g1. \rg1. \a. \b. \ra. \rb. \val. \body. \dval. \ihval. \dbody. \ihbody. mlet (ctxD g1 rg1) (tyD a ra) (tyD b rb) ihval ihbody : Π(g1 : Ctx). Π(rg1 : RCtx g1). Π(a : Ty). Π(b : Ty). Π(ra : RTy a). Π(rb : RTy b). Π(val : Expr g1 a). Π(body : Expr (ext a g1) b). Π(dval : HasR g1 rg1 a ra val). Π(ihval : MTm (ctxD g1 rg1) (tyD a ra)). Π(dbody : HasR (ext a g1) (ra, rg1) b rb body). Π(ihbody : MTm (ctxD (ext a g1) (ra, rg1)) (tyD b rb)). MTm (ctxD g1 rg1) (tyD b rb))
:let elab_if = (\g1. \rg1. \t1. \r1. \c. \th. \el. \dc. \ihc. \dth. \ihth. \del. \ihel. mif (ctxD g1 rg1) (tyD t1 r1) ihc ihth ihel : Π(g1 : Ctx). Π(rg1 : RCtx g1). Π(t1 : Ty). Π(r1 : RTy t1). Π(c : Expr g1 TBool). Π(th : Expr g1 t1). Π(el : Expr g1 t1). Π(dc : HasR g1 rg1 TBool RBool c). Π(ihc : MTm (ctxD g1 rg1) (tyD TBool RBool)). Π(dth : HasR g1 rg1 t1 r1 th). Π(ihth : MTm (ctxD g1 rg1) (tyD t1 r1)). Π(del : HasR g1 rg1 t1 r1 el). Π(ihel : MTm (ctxD g1 rg1) (tyD t1 r1)). MTm (ctxD g1 rg1) (tyD t1 r1))

-- ── Block B — intrinsic renaming (order-preserving embeddings)  NOT YET RUN ───
data OPE : Π(_ : MCtx). Π(_ : MCtx). Type where ope_nil : OPE mnil mnil ; ope_keep : Π(g : MCtx). Π(d : MCtx). Π(t : MTy). Π(_ : OPE g d). OPE (mcons t g) (mcons t d) ; ope_drop : Π(g : MCtx). Π(d : MCtx). Π(t : MTy). Π(_ : OPE g d). OPE g (mcons t d)
:let headCtx = (\g. indrec MCtx (\_. MTy : Π(_ : MCtx). Type) (MNat : MTy) (\t. \g0. \ih. t : Π(t : MTy). Π(g0 : MCtx). Π(_ : MTy). MTy) g : Π(_ : MCtx). MTy)
:let tailCtx = (\g. indrec MCtx (\_. MCtx : Π(_ : MCtx). Type) (mnil : MCtx) (\t. \g0. \ih. g0 : Π(t : MTy). Π(g0 : MCtx). Π(_ : MCtx). MCtx) g : Π(_ : MCtx). MCtx)
:let mvcase = (\gv. \tv. \vv. indrec MVar (\ga. \ta. \va. Π(d0 : MCtx). Π(f : Π(t : MTy). Π(_ : MVar (tailCtx ga) t). MVar d0 t). MVar (mcons (headCtx ga) d0) ta : Π(ga : MCtx). Π(ta : MTy). Π(_ : MVar ga ta). Type) (\g0. \t0. \d0. \f. mhere d0 t0 : Π(g0 : MCtx). Π(t0 : MTy). Π(d0 : MCtx). Π(f : Π(t : MTy). Π(_ : MVar g0 t). MVar d0 t). MVar (mcons t0 d0) t0) (\g0. \t0. \s0. \v0. \ih. \d0. \f. mthere d0 t0 s0 (f t0 v0) : Π(g0 : MCtx). Π(t0 : MTy). Π(s0 : MTy). Π(v0 : MVar g0 t0). Π(ih : Π(d0 : MCtx). Π(_ : Π(t : MTy). Π(_ : MVar (tailCtx g0) t). MVar d0 t). MVar (mcons (headCtx g0) d0) t0). Π(d0 : MCtx). Π(f : Π(t : MTy). Π(_ : MVar g0 t). MVar d0 t). MVar (mcons s0 d0) t0) vv : Π(gv : MCtx). Π(tv : MTy). Π(vv : MVar gv tv). Π(d0 : MCtx). Π(f : Π(t : MTy). Π(_ : MVar (tailCtx gv) t). MVar d0 t). MVar (mcons (headCtx gv) d0) tv)
:let ope_var = (\g. \d. \o. indrec OPE (\g1. \d1. \_. Π(t : MTy). Π(_ : MVar g1 t). MVar d1 t : Π(g1 : MCtx). Π(d1 : MCtx). Π(_ : OPE g1 d1). Type) (\t. \v. v : Π(t : MTy). Π(_ : MVar mnil t). MVar mnil t) (\g0. \d0. \s0. \o0. \ih. \t. \v. mvcase (mcons s0 g0) t v d0 ih : Π(g0 : MCtx). Π(d0 : MCtx). Π(s0 : MTy). Π(o0 : OPE g0 d0). Π(ih : Π(t : MTy). Π(_ : MVar g0 t). MVar d0 t). Π(t : MTy). Π(_ : MVar (mcons s0 g0) t). MVar (mcons s0 d0) t) (\g0. \d0. \s0. \o0. \ih. \t. \v. mthere d0 t s0 (ih t v) : Π(g0 : MCtx). Π(d0 : MCtx). Π(s0 : MTy). Π(o0 : OPE g0 d0). Π(ih : Π(t : MTy). Π(_ : MVar g0 t). MVar d0 t). Π(t : MTy). Π(_ : MVar g0 t). MVar (mcons s0 d0) t) o : Π(g : MCtx). Π(d : MCtx). Π(_ : OPE g d). Π(t : MTy). Π(_ : MVar g t). MVar d t)
:let ope_id = (\g. indrec MCtx (\g1. OPE g1 g1 : Π(_ : MCtx). Type) (ope_nil : OPE mnil mnil) (\t. \g0. \ih. ope_keep g0 g0 t ih : Π(t : MTy). Π(g0 : MCtx). Π(_ : OPE g0 g0). OPE (mcons t g0) (mcons t g0)) g : Π(g : MCtx). OPE g g)
:let ope_tm = (\g. \t. \m. indrec MTm (\g1. \t1. \_. Π(d : MCtx). Π(_ : OPE g1 d). MTm d t1 : Π(g1 : MCtx). Π(t1 : MTy). Π(_ : MTm g1 t1). Type) (\g0. \t0. \v. \d. \o. mvar d t0 (ope_var g0 d o t0 v) : Π(g0 : MCtx). Π(t0 : MTy). Π(v : MVar g0 t0). Π(d : MCtx). Π(o : OPE g0 d). MTm d t0) (\g0. \p. \n. \ev. \d. \o. msub_intro d p n ev : Π(g0 : MCtx). Π(p : Π(_ : Nat). Bool). Π(n : Nat). Π(ev : IsTrue (p n)). Π(d : MCtx). Π(o : OPE g0 d). MTm d (MSub p)) (\g0. \b. \d. \o. mbool_intro d b : Π(g0 : MCtx). Π(b : Bool). Π(d : MCtx). Π(o : OPE g0 d). MTm d MBool) (\g0. \a. \b. \f. \ihf. \x. \ihx. \d. \o. mapp d a b (ihf d o) (ihx d o) : Π(g0 : MCtx). Π(a : MTy). Π(b : MTy). Π(f : MTm g0 (MFun a b)). Π(ihf : Π(d : MCtx). Π(_ : OPE g0 d). MTm d (MFun a b)). Π(x : MTm g0 a). Π(ihx : Π(d : MCtx). Π(_ : OPE g0 d). MTm d a). Π(d : MCtx). Π(o : OPE g0 d). MTm d b) (\g0. \a. \b. \body. \ihbody. \d. \o. mlam d a b (ihbody (mcons a d) (ope_keep g0 d a o)) : Π(g0 : MCtx). Π(a : MTy). Π(b : MTy). Π(body : MTm (mcons a g0) b). Π(ihbody : Π(d : MCtx). Π(_ : OPE (mcons a g0) d). MTm d b). Π(d : MCtx). Π(o : OPE g0 d). MTm d (MFun a b)) (\g0. \t0. \c. \ihc. \th. \ihth. \el. \ihel. \d. \o. mif d t0 (ihc d o) (ihth d o) (ihel d o) : Π(g0 : MCtx). Π(t0 : MTy). Π(c : MTm g0 MBool). Π(ihc : Π(d : MCtx). Π(_ : OPE g0 d). MTm d MBool). Π(th : MTm g0 t0). Π(ihth : Π(d : MCtx). Π(_ : OPE g0 d). MTm d t0). Π(el : MTm g0 t0). Π(ihel : Π(d : MCtx). Π(_ : OPE g0 d). MTm d t0). Π(d : MCtx). Π(o : OPE g0 d). MTm d t0) (\g0. \a. \b. \val. \ihval. \body. \ihbody. \d. \o. mlet d a b (ihval d o) (ihbody (mcons a d) (ope_keep g0 d a o)) : Π(g0 : MCtx). Π(a : MTy). Π(b : MTy). Π(val : MTm g0 a). Π(ihval : Π(d : MCtx). Π(_ : OPE g0 d). MTm d a). Π(body : MTm (mcons a g0) b). Π(ihbody : Π(d : MCtx). Π(_ : OPE (mcons a g0) d). MTm d b). Π(d : MCtx). Π(o : OPE g0 d). MTm d b) (\g0. \p. \q. \imp. \m. \ihm. \d. \o. msub_weaken d p q imp (ihm d o) : Π(g0 : MCtx). Π(p : Π(_ : Nat). Bool). Π(q : Π(_ : Nat). Bool). Π(imp : Π(n : Nat). Π(_ : IsTrue (p n)). IsTrue (q n)). Π(m : MTm g0 (MSub p)). Π(ihm : Π(d : MCtx). Π(_ : OPE g0 d). MTm d (MSub p)). Π(d : MCtx). Π(o : OPE g0 d). MTm d (MSub q)) m : Π(g : MCtx). Π(t : MTy). Π(_ : MTm g t). Π(d : MCtx). Π(_ : OPE g d). MTm d t)
:let mweaken = (\g. \s. \t. \m. ope_tm g t m (mcons s g) (ope_drop g g s (ope_id g)) : Π(g : MCtx). Π(s : MTy). Π(t : MTy). Π(_ : MTm g t). MTm (mcons s g) t)

-- ── Block C — subtyping coercion + the full elaboration ───────────────────────
-- elabSub reifies a Sub derivation as an MLTT coercion. SubBase ↦ msub_weaken
-- (carry the predicate implication). SubFn ↦ an η-expanded coercion: λx. ihc (f (ihd x)),
-- where f must be WEAKENED (mweaken) under the fresh domain binder — this is the
-- one spot that consumes Block B, and it fires both variance IHs in opposite directions.
:let elabSub = (\t. \r. \r2. \s. indrec Sub (\t1. \r1. \r2a. \sa. Π(g : MCtx). Π(_ : MTm g (tyD t1 r1)). MTm g (tyD t1 r2a) : Π(t1 : Ty). Π(r1 : RTy t1). Π(r2a : RTy t1). Π(_ : Sub t1 r1 r2a). Type) (\p. \q. \imp. \g. \m. msub_weaken g p q imp m : Π(p : Π(_ : Nat). Bool). Π(q : Π(_ : Nat). Bool). Π(imp : Π(n : Nat). Π(_ : IsTrue (p n)). IsTrue (q n)). Π(g : MCtx). Π(m : MTm g (MSub p)). MTm g (MSub q)) (\a. \b. \ra. \ra'. \rb. \rb'. \sd. \ihd. \sc. \ihc. \g. \f. mlam g (tyD a ra') (tyD b rb') (ihc (mcons (tyD a ra') g) (mapp (mcons (tyD a ra') g) (tyD a ra) (tyD b rb) (mweaken g (tyD a ra') (MFun (tyD a ra) (tyD b rb)) f) (ihd (mcons (tyD a ra') g) (mvar (mcons (tyD a ra') g) (tyD a ra') (mhere g (tyD a ra')))))) : Π(a : Ty). Π(b : Ty). Π(ra : RTy a). Π(ra' : RTy a). Π(rb : RTy b). Π(rb' : RTy b). Π(sd : Sub a ra' ra). Π(ihd : Π(g : MCtx). Π(_ : MTm g (tyD a ra')). MTm g (tyD a ra)). Π(sc : Sub b rb rb'). Π(ihc : Π(g : MCtx). Π(_ : MTm g (tyD b rb)). MTm g (tyD b rb')). Π(g : MCtx). Π(f : MTm g (MFun (tyD a ra) (tyD b rb))). MTm g (MFun (tyD a ra') (tyD b rb'))) s : Π(t : Ty). Π(r : RTy t). Π(r2 : RTy t). Π(_ : Sub t r r2). Π(g : MCtx). Π(_ : MTm g (tyD t r)). MTm g (tyD t r2))
:let elab_sub = (\g1. \rg1. \t1. \r1. \r2. \e. \d. \ihd. \s. elabSub t1 r1 r2 s (ctxD g1 rg1) ihd : Π(g1 : Ctx). Π(rg1 : RCtx g1). Π(t1 : Ty). Π(r1 : RTy t1). Π(r2 : RTy t1). Π(e : Expr g1 t1). Π(d : HasR g1 rg1 t1 r1 e). Π(ihd : MTm (ctxD g1 rg1) (tyD t1 r1)). Π(s : Sub t1 r1 r2). MTm (ctxD g1 rg1) (tyD t1 r2))
-- THE ELABORATION: HasR derivation → intrinsically-typed MLTT term at the translated type
:let elab = (\g. \rg. \t. \r. \e. \d. indrec HasR (\g1. \rg1. \t1. \r1. \e1. \da. MTm (ctxD g1 rg1) (tyD t1 r1) : Π(g1 : Ctx). Π(rg1 : RCtx g1). Π(t1 : Ty). Π(r1 : RTy t1). Π(e1 : Expr g1 t1). Π(_ : HasR g1 rg1 t1 r1 e1). Type) elab_int elab_bool elab_var elab_app elab_if elab_sub elab_lam elab_let d : Π(g : Ctx). Π(rg : RCtx g). Π(t : Ty). Π(r : RTy t). Π(e : Expr g t). Π(_ : HasR g rg t r e). MTm (ctxD g rg) (tyD t r))
-- Showcase smokes: elaborate the SAME derivations the operational `fund` proof uses.
-- smoke_sub fires RT_Sub (→ msub_weaken); smoke_lam fires RT_Lam (→ mlam, a binder);
-- smoke_let fires RT_Let (→ mlet). smoke_fn_coe reifies a genuine FUNCTION-subtyping
-- derivation, so it drives the SubFn coercion — the one path that consumes mweaken.
:let smoke_sub = (elab gF rgF TInt rge1 eF d_sub : MTm (ctxD gF rgF) (MSub ge1))
:let smoke_lam = (elab empty star (TFn TInt TInt) (RFn TInt TInt rge2 rge2) (ELam empty TInt TInt idbody) d_idlam : MTm mnil (MFun (MSub ge2) (MSub ge2)))
:let smoke_let = (elab empty star TInt rge2 (ELet empty TInt TInt (ELitInt empty n2) idbody) d_let : MTm mnil (MSub ge2))
:let smoke_fn_coe = (elabSub (TFn TInt TInt) rc12 rc21 sub_fn21 : Π(g : MCtx). Π(_ : MTm g (MFun (MSub ge1) (MSub ge2))). MTm g (MFun (MSub ge2) (MSub ge1)))
:i elabSub
:i elab
:i smoke_lam
:i smoke_fn_coe
