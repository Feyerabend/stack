-- lark-subst.lcore
--
-- Phase 5: Semantic substitution for Lark's STLC.
-- Checked by lcore (proof/code/core/).
--
-- Run:  cd proof/code/core && cat ../../lark/lark-typing.lcore ../../lark/lark-subst.lcore | grep -v "^--" | grep -v "^$" | ./lcore
--
-- CORRESPONDENCE TABLE
-- ====================
-- Every definition maps to a concrete piece of Lark's runtime or type system.
--
--   Lark source / runtime            lcore proof             location
--   ──────────────────────────────── ─────────────────────── ──────────────────
--   CEK ENV  (name → value)          SemCtx Γ                cek.py Env
--   env.lookup x                     sem_lookup v env         cek.py Var case
--   canonical value (literal / fn)   dummy_expr t g           —
--   subst x↦val in body              sub_ground e env         tac_vm.py eval
--   is_value e                       IsVal e                  cek.py is_whnf
--   e →β e'                          Step e e'               (reduction)
--
-- WHAT IS PROVED HERE:
--   1. SemCtx and sem_lookup — semantic environments + variable lookup. COMPLETE.
--      The SemCtx motive trick (motive unfolds definitionally via indrec Ctx)
--      is the key insight that avoids index refinement for the here/there cases.
--
--   2. dummy_expr — canonical term of any type. COMPLETE.
--
--   3. SemCtx_d, sem_lookup_d, weaken_semctx_d — open semantic environments
--      parametrised by the output context d. When d = empty these coincide
--      definitionally with SemCtx and sem_lookup. COMPLETE.
--
--   4. ins / shift / wk / wk0 — weakening DEFINED IN LCORE with an explicit
--      Nat cutoff (added 2026-07-16, the V3 Pitch-2 rebase). The 2026-06-18
--      blocker ("ext-commutativity is not definitional") dissolves once the
--      cutoff is explicit: ins a (succ n) (ext s g) ≡ ext s (ins a n g)
--      COMPUTES even at neutral g/n, so wk's ELam case uses its IH at
--      (succ n) definitionally — no commutativity equation, no transport.
--      wk0 (= wk at cutoff zero) has the kernel primitive's exact type and
--      agrees with it definitionally on concrete trees (smokes below prove
--      instances by refl). Unlike the kernel primitive — which crashes on a
--      constructor with neutral children (eval.c weaken_expr_val exit(1)) —
--      wk computes ONE LAYER at a time, so the substitution lemmas of V3
--      Pitch 2 (lark-refine.lcore) can be proven by indrec Expr. COMPLETE.
--
--   5. sub_open — generalised substitution into any output context d. COMPLETE.
--      Motive: M g t _ = Π(d : Ctx). SemCtx_d d g → Expr d t
--      ELam case: uses wk0 (lcore-level weakening) to lift env entries,
--      then places the lambda param as EVar (here d a1) in the result body.
--      REBASED 2026-07-16 from the kernel weaken primitive onto wk0 —
--      required so that V3 Pitch 2 can REASON about substitution; on every
--      concrete tree the two agree definitionally, so nothing downstream
--      changes its normal forms.
--
--   6. sub_ground — semantic substitution, now defined as sub_open at d=empty.
--      COMPLETE and CORRECT for ALL cases including ELam. COMPLETE.
--
--   7. IsVal — closed-value predicate. COMPLETE.
--
-- KERNEL PRIMITIVE (C-level, RETIRED from the proof-critical path 2026-07-16):
--   weaken : Π(a : Ty). Π(g : Ctx). Π(t : Ty). Expr g t → Expr (ext a g) t
--   Implemented in eval.c (weaken_expr_val) by structural recursion on the
--   VL_INDCON tree, shifting de Bruijn indices with a cutoff parameter.
--   It computes only on FULLY CONCRETE trees (a constructor with neutral
--   children crashes the checker — probed 2026-07-16), so no lemma about it
--   can be proven by induction. It remains available (smokes wk1/wk2 below,
--   plus the refl agreement smokes) but sub_open no longer calls it.

-- ── SemCtx : semantic environments ────────────────────────────────────────────
-- SemCtx g  is a snoc list pairing each Γ-variable with a closed expression.
--
--   SemCtx empty       =  Unit
--   SemCtx (ext t g)   =  Σ(_ : Expr empty t). SemCtx g
--
-- Lark CEK analogue: the ENV component of a CEK state.
-- The indrec Ctx computation rule makes SemCtx unfold definitionally,
-- which is what enables sem_lookup to avoid needing Id proofs.

:let SemCtx = (\g. indrec Ctx (\g1. Type : Ctx → Type_1) (Unit : Type) (\t. \g1. \ih. Σ(_ : Expr empty t). ih : Π(t : Ty). Π(g1 : Ctx). Type → Type) g : Ctx → Type)

-- ── sem_lookup : variable lookup in SemCtx ────────────────────────────────────
-- sem_lookup g t v env  retrieves the expression for variable v from env.
-- Mirrors infer.py / cek.py Var case: look up x in the environment.
--
-- KEY TRICK: motive  M g t _ = SemCtx g → Expr empty t
--   SemCtx unfolds: SemCtx (ext t1 g1) = Σ(_ : Expr empty t1). SemCtx g1
--   here case:  fst env : Expr empty t1  (no index equation needed!)
--   there case: ih (snd env) via IH     (recurse on tail)
-- This is the insight that avoids the index-refinement limitation of indrec.

:let sem_lookup = (\g. \t. \v. indrec Var (\g1. \t1. \_. SemCtx g1 → Expr empty t1 : Π(g1 : Ctx). Π(t1 : Ty). Var g1 t1 → Type) (\g1. \t1. \env. fst env : Π(g1 : Ctx). Π(t1 : Ty). SemCtx (ext t1 g1) → Expr empty t1) (\g1. \t1. \s. \v1. \ih. \env. ih (snd env) : Π(g1 : Ctx). Π(t1 : Ty). Π(s : Ty). Var g1 t1 → (SemCtx g1 → Expr empty t1) → SemCtx (ext s g1) → Expr empty t1) v : Π(g : Ctx). Π(t : Ty). Var g t → SemCtx g → Expr empty t)

-- ── dummy_expr : canonical term for any type ───────────────────────────────────
-- dummy_expr t g  produces a canonical expression of type t in context g.
-- Defined by indrec Ty with motive  \t. Π(g : Ctx). Expr g t.
-- No longer needed as an ELam placeholder (sub_open handles it correctly),
-- but retained for testing and as a utility.

:let dummy_expr = (\t. \g. indrec Ty (\t1. Π(g1 : Ctx). Expr g1 t1 : Ty → Type) (\g1. ELitInt g1 zero : Π(g1 : Ctx). Expr g1 TInt) (\g1. ELitFlt g1 : Π(g1 : Ctx). Expr g1 TFloat) (\g1. ELitBool g1 true : Π(g1 : Ctx). Expr g1 TBool) (\g1. ELitStr g1 : Π(g1 : Ctx). Expr g1 TStr) (\g1. EUnit g1 : Π(g1 : Ctx). Expr g1 TUnit) (\a. \ih_a. \b. \ih_b. \g1. ELam g1 a b (ih_b (ext a g1)) : Π(a : Ty). (Π(g1 : Ctx). Expr g1 a) → Π(b : Ty). (Π(g1 : Ctx). Expr g1 b) → Π(g1 : Ctx). Expr g1 (TFn a b)) t g : Π(t : Ty). Π(g : Ctx). Expr g t)

-- ── ins / shift / wk : weakening defined in lcore (V3 Pitch-2 rebase) ─────────
-- ins a n g — insert type a at depth n in g:
--   ins a zero g             ≡ ext a g              (any g, incl. neutral)
--   ins a (succ m) (ext s g) ≡ ext s (ins a m g)    (neutral tail/m fine)
--   ins a (succ m) empty     = empty                (junk = NO-OP; unreachable
--                                                    for well-typed variables)
-- The succ case ignores the indrec Ctx IH and recurses through the OUTER
-- natrec ih — that is what makes the second equation definitional.
-- JUNK CASE RATIFIED 2026-07-16 (with Set): out-of-range insertion is a no-op
-- (returns g unchanged), NOT a clamp to insert-at-end.  The clamp broke the
-- exchange law ins_ins (counterexample i=1, d=empty); a no-op commutes with
-- everything, so ins_ins below holds unconditionally — no in-range bound.

:let ins = (\a. \n. natrec (\_. Π(g : Ctx). Ctx : Π(_ : Nat). Type) (\g. ext a g : Π(g : Ctx). Ctx) (\m. \ih. \g. indrec Ctx (\_. Ctx : Ctx → Type) (empty : Ctx) (\s. \g1. \ihc. ext s (ih g1) : Π(s : Ty). Π(g1 : Ctx). Π(ihc : Ctx). Ctx) g : Π(m : Nat). Π(ih : Π(g : Ctx). Ctx). Π(g : Ctx). Ctx) n : Π(a : Ty). Π(n : Nat). Π(g : Ctx). Ctx)

-- shift a g t v n : Var (ins a n g) t — de Bruijn shift at cutoff n.
-- By indrec Var; each case natrecs on the cutoff. At zero the shift is the
-- uniform there-wrap; at succ m the context is ext-headed so ins computes
-- and the here/there constructors land definitionally.

:let shift = (\a. \g. \t. \v. indrec Var (\g1. \t1. \v1. Π(n : Nat). Var (ins a n g1) t1 : Π(g1 : Ctx). Π(t1 : Ty). Var g1 t1 → Type) (\g1. \t1. \n. natrec (\n1. Var (ins a n1 (ext t1 g1)) t1 : Π(n1 : Nat). Type) (there (ext t1 g1) t1 a (here g1 t1)) (\m. \ihn. here (ins a m g1) t1 : Π(m : Nat). Π(ihn : Var (ins a m (ext t1 g1)) t1). Var (ins a (succ m) (ext t1 g1)) t1) n : Π(g1 : Ctx). Π(t1 : Ty). Π(n : Nat). Var (ins a n (ext t1 g1)) t1) (\g1. \t1. \s. \v1. \ih. \n. natrec (\n1. Var (ins a n1 (ext s g1)) t1 : Π(n1 : Nat). Type) (there (ext s g1) t1 a (there g1 t1 s v1)) (\m. \ihn. there (ins a m g1) t1 s (ih m) : Π(m : Nat). Π(ihn : Var (ins a m (ext s g1)) t1). Var (ins a (succ m) (ext s g1)) t1) n : Π(g1 : Ctx). Π(t1 : Ty). Π(s : Ty). Π(v1 : Var g1 t1). Π(ih : Π(n : Nat). Var (ins a n g1) t1). Π(n : Nat). Var (ins a n (ext s g1)) t1) v : Π(a : Ty). Π(g : Ctx). Π(t : Ty). Π(v : Var g t). Π(n : Nat). Var (ins a n g) t)

-- wk a g t e n : Expr (ins a n g) t — weakening by indrec Expr.
-- THE CRUX: the ELam/ELet cases use the IH at (succ n); the goal slot is
-- Expr (ext a1 (ins a n g1)) b1 and ins a (succ n) (ext a1 g1) computes to
-- exactly that. Unlike the kernel primitive, wk computes one constructor
-- layer at a time, so lemmas about it fall to indrec Expr.

:let wk = (\a. \g. \t. \e. indrec Expr (\g1. \t1. \e1. Π(n : Nat). Expr (ins a n g1) t1 : Π(g1 : Ctx). Π(t1 : Ty). Expr g1 t1 → Type) (\g1. \m. \n. ELitInt (ins a n g1) m : Π(g1 : Ctx). Π(m : Nat). Π(n : Nat). Expr (ins a n g1) TInt) (\g1. \n. ELitFlt (ins a n g1) : Π(g1 : Ctx). Π(n : Nat). Expr (ins a n g1) TFloat) (\g1. \b. \n. ELitBool (ins a n g1) b : Π(g1 : Ctx). Π(b : Bool). Π(n : Nat). Expr (ins a n g1) TBool) (\g1. \n. ELitStr (ins a n g1) : Π(g1 : Ctx). Π(n : Nat). Expr (ins a n g1) TStr) (\g1. \n. EUnit (ins a n g1) : Π(g1 : Ctx). Π(n : Nat). Expr (ins a n g1) TUnit) (\g1. \t1. \v1. \n. EVar (ins a n g1) t1 (shift a g1 t1 v1 n) : Π(g1 : Ctx). Π(t1 : Ty). Π(v1 : Var g1 t1). Π(n : Nat). Expr (ins a n g1) t1) (\g1. \a1. \b1. \bd. \ihbd. \n. ELam (ins a n g1) a1 b1 (ihbd (succ n)) : Π(g1 : Ctx). Π(a1 : Ty). Π(b1 : Ty). Π(bd : Expr (ext a1 g1) b1). Π(ihbd : Π(n : Nat). Expr (ins a n (ext a1 g1)) b1). Π(n : Nat). Expr (ins a n g1) (TFn a1 b1)) (\g1. \a1. \b1. \f. \ihf. \x. \ihx. \n. EApp (ins a n g1) a1 b1 (ihf n) (ihx n) : Π(g1 : Ctx). Π(a1 : Ty). Π(b1 : Ty). Π(f : Expr g1 (TFn a1 b1)). Π(ihf : Π(n : Nat). Expr (ins a n g1) (TFn a1 b1)). Π(x : Expr g1 a1). Π(ihx : Π(n : Nat). Expr (ins a n g1) a1). Π(n : Nat). Expr (ins a n g1) b1) (\g1. \a1. \b1. \val. \ihv. \bd. \ihbd. \n. ELet (ins a n g1) a1 b1 (ihv n) (ihbd (succ n)) : Π(g1 : Ctx). Π(a1 : Ty). Π(b1 : Ty). Π(val : Expr g1 a1). Π(ihv : Π(n : Nat). Expr (ins a n g1) a1). Π(bd : Expr (ext a1 g1) b1). Π(ihbd : Π(n : Nat). Expr (ins a n (ext a1 g1)) b1). Π(n : Nat). Expr (ins a n g1) b1) (\g1. \t1. \c. \ihc. \th. \ihth. \el. \ihel. \n. EIf (ins a n g1) t1 (ihc n) (ihth n) (ihel n) : Π(g1 : Ctx). Π(t1 : Ty). Π(c : Expr g1 TBool). Π(ihc : Π(n : Nat). Expr (ins a n g1) TBool). Π(th : Expr g1 t1). Π(ihth : Π(n : Nat). Expr (ins a n g1) t1). Π(el : Expr g1 t1). Π(ihel : Π(n : Nat). Expr (ins a n g1) t1). Π(n : Nat). Expr (ins a n g1) t1) e : Π(a : Ty). Π(g : Ctx). Π(t : Ty). Π(e : Expr g t). Π(n : Nat). Expr (ins a n g) t)

-- wk0 : the kernel primitive's exact type; ins a zero g ≡ ext a g makes the
-- ascription definitional.

:let wk0 = (\a. \g. \t. \e. wk a g t e zero : Π(a : Ty). Π(g : Ctx). Π(t : Ty). Π(e : Expr g t). Expr (ext a g) t)

-- ── SemCtx_d : open semantic environments ─────────────────────────────────────
-- SemCtx_d d g  maps each Γ-variable to an Expr d t  (open in context d).
-- SemCtx_d empty g = SemCtx g  definitionally.
-- Used by sub_open to substitute into expressions that remain open in d.

:let SemCtx_d = (\d. \g. indrec Ctx (\g1. Type : Ctx → Type_1) (Unit : Type) (\t. \g1. \ih. Σ(_ : Expr d t). ih : Π(t : Ty). Π(g1 : Ctx). Type → Type) g : Ctx → Ctx → Type)

-- ── sem_lookup_d : variable lookup in SemCtx_d ────────────────────────────────
-- sem_lookup_d d g t v env_d  looks up variable v in an open environment.
-- Structurally identical to sem_lookup; parametrised by output context d.

:let sem_lookup_d = (\d. \g. \t. \v. indrec Var (\g1. \t1. \_. SemCtx_d d g1 → Expr d t1 : Π(g1 : Ctx). Π(t1 : Ty). Var g1 t1 → Type) (\g1. \t1. \env. fst env : Π(g1 : Ctx). Π(t1 : Ty). SemCtx_d d (ext t1 g1) → Expr d t1) (\g1. \t1. \s. \v1. \ih. \env. ih (snd env) : Π(g1 : Ctx). Π(t1 : Ty). Π(s : Ty). Var g1 t1 → (SemCtx_d d g1 → Expr d t1) → SemCtx_d d (ext s g1) → Expr d t1) v : Π(d : Ctx). Π(g : Ctx). Π(t : Ty). Var g t → SemCtx_d d g → Expr d t)

-- ── weaken_semctx_d : lift all SemCtx_d entries by inserting a new binding ────
-- weaken_semctx_d a d g env_d  applies  weaken a d t  to each Expr d t entry,
-- producing  SemCtx_d (ext a d) g.
-- Uses lcore-level wk0 a d t : Expr d t → Expr (ext a d) t (same signature as
-- the kernel primitive; REBASED 2026-07-16 so the proof path is inductive).

:let weaken_semctx_d = (\a. \d. \g. indrec Ctx (\g1. SemCtx_d d g1 → SemCtx_d (ext a d) g1 : Ctx → Type) (\e. star : SemCtx_d d empty → SemCtx_d (ext a d) empty) (\t. \g1. \ih. \e. (wk0 a d t (fst e), ih (snd e)) : Π(t : Ty). Π(g1 : Ctx). (SemCtx_d d g1 → SemCtx_d (ext a d) g1) → SemCtx_d d (ext t g1) → SemCtx_d (ext a d) (ext t g1)) g : Π(a : Ty). Π(d : Ctx). Π(g : Ctx). SemCtx_d d g → SemCtx_d (ext a d) g)

-- ── sub_open : generalised substitution into any output context ────────────────
-- sub_open g t e d env_d : Expr d t
-- Substitutes env_d (mapping Γ → Expr d) into e : Expr g t, producing Expr d t.
-- Motive: M g t _ = Π(d : Ctx). SemCtx_d d g → Expr d t
--
-- ELam case (THE KEY FIX):
--   The body bd : Expr (ext a g) b  needs  SemCtx_d (ext a d) (ext a g).
--   We extend the environment with the lambda param as
--     EVar (ext a d) a (here d a) : Expr (ext a d) a
--   and weaken the existing env with weaken_semctx_d:
--     weaken_semctx_d a d g env_d : SemCtx_d (ext a d) g
--   Result: ELam d a b (ih_bd (ext a d) (EVar..., weakened_env))
--
-- ELet case is HOMOMORPHIC (mirrors ELam): it emits an ELet node, weakening
--   the env under the binder exactly like ELam — it does NOT reduce the let.
--   (Reduction of a let is the operational system's job: StepLetBeta fires it.)
--   This is what makes sub_open a genuine substitution: the identity-subst
--   fact  sub_ground empty t X star = X  then holds for ALL closed X, lets and
--   all — which the RT_Lam/RT_Let β-contractum fusion (Pitch 2) bottoms out on.
--   An earlier version inlined lets here; that made substitution reduce, and
--   the substitution lemma false on any let-containing term. Ratified with Set.
--
-- All cases verified by lcore NbE.

:let sub_open = (\g. \t. \e. \d. \env_d. indrec Expr (\g1. \t1. \_. Π(d1 : Ctx). SemCtx_d d1 g1 → Expr d1 t1 : Π(g1 : Ctx). Π(t1 : Ty). Expr g1 t1 → Type) (\g1. \n. \d1. \e1. ELitInt d1 n : Π(g1 : Ctx). Π(n : Nat). Π(d1 : Ctx). SemCtx_d d1 g1 → Expr d1 TInt) (\g1. \d1. \e1. ELitFlt d1 : Π(g1 : Ctx). Π(d1 : Ctx). SemCtx_d d1 g1 → Expr d1 TFloat) (\g1. \b. \d1. \e1. ELitBool d1 b : Π(g1 : Ctx). Π(b : Bool). Π(d1 : Ctx). SemCtx_d d1 g1 → Expr d1 TBool) (\g1. \d1. \e1. ELitStr d1 : Π(g1 : Ctx). Π(d1 : Ctx). SemCtx_d d1 g1 → Expr d1 TStr) (\g1. \d1. \e1. EUnit d1 : Π(g1 : Ctx). Π(d1 : Ctx). SemCtx_d d1 g1 → Expr d1 TUnit) (\g1. \t1. \v1. \d1. \e1. sem_lookup_d d1 g1 t1 v1 e1 : Π(g1 : Ctx). Π(t1 : Ty). Var g1 t1 → Π(d1 : Ctx). SemCtx_d d1 g1 → Expr d1 t1) (\g1. \a1. \b1. \bd. \ih_bd. \d1. \e1. ELam d1 a1 b1 (ih_bd (ext a1 d1) (EVar (ext a1 d1) a1 (here d1 a1), weaken_semctx_d a1 d1 g1 e1)) : Π(g1 : Ctx). Π(a1 : Ty). Π(b1 : Ty). Expr (ext a1 g1) b1 → (Π(d1 : Ctx). SemCtx_d d1 (ext a1 g1) → Expr d1 b1) → Π(d1 : Ctx). SemCtx_d d1 g1 → Expr d1 (TFn a1 b1)) (\g1. \a1. \b1. \f. \ih_f. \x. \ih_x. \d1. \e1. EApp d1 a1 b1 (ih_f d1 e1) (ih_x d1 e1) : Π(g1 : Ctx). Π(a1 : Ty). Π(b1 : Ty). Expr g1 (TFn a1 b1) → (Π(d1 : Ctx). SemCtx_d d1 g1 → Expr d1 (TFn a1 b1)) → Expr g1 a1 → (Π(d1 : Ctx). SemCtx_d d1 g1 → Expr d1 a1) → Π(d1 : Ctx). SemCtx_d d1 g1 → Expr d1 b1) (\g1. \a1. \b1. \val. \ih_v. \bd. \ih_bd. \d1. \e1. ELet d1 a1 b1 (ih_v d1 e1) (ih_bd (ext a1 d1) (EVar (ext a1 d1) a1 (here d1 a1), weaken_semctx_d a1 d1 g1 e1)) : Π(g1 : Ctx). Π(a1 : Ty). Π(b1 : Ty). Expr g1 a1 → (Π(d1 : Ctx). SemCtx_d d1 g1 → Expr d1 a1) → Expr (ext a1 g1) b1 → (Π(d1 : Ctx). SemCtx_d d1 (ext a1 g1) → Expr d1 b1) → Π(d1 : Ctx). SemCtx_d d1 g1 → Expr d1 b1) (\g1. \t1. \c. \ih_c. \th. \ih_th. \el. \ih_el. \d1. \e1. EIf d1 t1 (ih_c d1 e1) (ih_th d1 e1) (ih_el d1 e1) : Π(g1 : Ctx). Π(t1 : Ty). Expr g1 TBool → (Π(d1 : Ctx). SemCtx_d d1 g1 → Expr d1 TBool) → Expr g1 t1 → (Π(d1 : Ctx). SemCtx_d d1 g1 → Expr d1 t1) → Expr g1 t1 → (Π(d1 : Ctx). SemCtx_d d1 g1 → Expr d1 t1) → Π(d1 : Ctx). SemCtx_d d1 g1 → Expr d1 t1) e d env_d : Π(g : Ctx). Π(t : Ty). Expr g t → Π(d : Ctx). SemCtx_d d g → Expr d t)

-- ── sub_ground : semantic substitution ────────────────────────────────────────
-- sub_ground g t e env  substitutes env : SemCtx g into e : Expr g t,
-- producing a closed  Expr empty t.
-- Now defined as  sub_open g t e empty env  (d = empty specialisation).
-- SemCtx g = SemCtx_d empty g  definitionally, so no coercion is needed.
-- CORRECT for ALL constructors including ELam. COMPLETE.

:let sub_ground = (\g. \t. \e. \env. sub_open g t e empty env : Π(g : Ctx). Π(t : Ty). Expr g t → SemCtx g → Expr empty t)

-- ── Pitch-2 substitution lemmas (V3, the σ-fusion pile) ───────────────────────
-- Brick 1 — wk_lookup: lookup commutes with environment weakening.
--   sem_lookup_d (ext a d) g t v (weaken_semctx_d a d g env)
--     = wk0 a d t (sem_lookup_d d g t v env)
-- Read: looking a variable up in a weakened environment is the same as
-- weakening the entry you would have looked up. This is the base commutation
-- the fusion / cancellation lemmas rest on. Proof by indrec Var:
--   here-case  — both sides reduce to  wk0 a d t (fst env)  (definitional, refl);
--   there-case — the IH at the tail (snd env) is the goal on the nose.
-- No cutoff generalisation, no J: weaken_semctx_d changes only the OUTPUT
-- context (d → ext a d), so the source variable v is looked up unchanged.

:let wk_lookup = (\a. \g. \t. \v. indrec Var (\g1. \t1. \v1. Π(d : Ctx). Π(env : SemCtx_d d g1). Id (Expr (ext a d) t1) (sem_lookup_d (ext a d) g1 t1 v1 (weaken_semctx_d a d g1 env)) (wk0 a d t1 (sem_lookup_d d g1 t1 v1 env)) : Π(g1 : Ctx). Π(t1 : Ty). Var g1 t1 → Type) (\g1. \t1. \d. \env. refl (wk0 a d t1 (fst env)) : Π(g1 : Ctx). Π(t1 : Ty). Π(d : Ctx). Π(env : SemCtx_d d (ext t1 g1)). Id (Expr (ext a d) t1) (sem_lookup_d (ext a d) (ext t1 g1) t1 (here g1 t1) (weaken_semctx_d a d (ext t1 g1) env)) (wk0 a d t1 (sem_lookup_d d (ext t1 g1) t1 (here g1 t1) env))) (\g1. \t1. \s. \v1. \ih. \d. \env. ih d (snd env) : Π(g1 : Ctx). Π(t1 : Ty). Π(s : Ty). Π(v1 : Var g1 t1). (Π(d : Ctx). Π(env : SemCtx_d d g1). Id (Expr (ext a d) t1) (sem_lookup_d (ext a d) g1 t1 v1 (weaken_semctx_d a d g1 env)) (wk0 a d t1 (sem_lookup_d d g1 t1 v1 env))) → Π(d : Ctx). Π(env : SemCtx_d d (ext s g1)). Id (Expr (ext a d) t1) (sem_lookup_d (ext a d) (ext s g1) t1 (there g1 t1 s v1) (weaken_semctx_d a d (ext s g1) env)) (wk0 a d t1 (sem_lookup_d d (ext s g1) t1 (there g1 t1 s v1) env))) v : Π(a : Ty). Π(g : Ctx). Π(t : Ty). Π(v : Var g t). Π(d : Ctx). Π(env : SemCtx_d d g). Id (Expr (ext a d) t) (sem_lookup_d (ext a d) g t v (weaken_semctx_d a d g env)) (wk0 a d t (sem_lookup_d d g t v env)))
:i wk_lookup

-- Brick 2a — del + sdl: how a front-inserted binder interacts with lookup.
-- del a n g d : SemCtx_d d (ins a n g) → SemCtx_d d g  removes the entry the
-- environment assigns to the binder inserted at depth n (drop head at n=0,
-- keep-and-recurse in the tail at succ). natrec on n; succ case indrec Ctx on g.

:let del = (\a. \n. natrec (\n1. Π(g : Ctx). Π(d : Ctx). SemCtx_d d (ins a n1 g) → SemCtx_d d g : Π(_ : Nat). Type) (\g. \d. \env. snd env : Π(g : Ctx). Π(d : Ctx). SemCtx_d d (ins a zero g) → SemCtx_d d g) (\m. \ih. \g. \d. \env. indrec Ctx (\g1. SemCtx_d d (ins a (succ m) g1) → SemCtx_d d g1 : Ctx → Type) (\e. e : SemCtx_d d (ins a (succ m) empty) → SemCtx_d d empty) (\s. \g1. \ihc. \e. (fst e, ih g1 d (snd e)) : Π(s : Ty). Π(g1 : Ctx). (SemCtx_d d (ins a (succ m) g1) → SemCtx_d d g1) → SemCtx_d d (ins a (succ m) (ext s g1)) → SemCtx_d d (ext s g1)) g env : Π(m : Nat). Π(ih : Π(g : Ctx). Π(d : Ctx). SemCtx_d d (ins a m g) → SemCtx_d d g). Π(g : Ctx). Π(d : Ctx). SemCtx_d d (ins a (succ m) g) → SemCtx_d d g) n : Π(a : Ty). Π(n : Nat). Π(g : Ctx). Π(d : Ctx). SemCtx_d d (ins a n g) → SemCtx_d d g)

-- sdl: substituting a shifted variable through env = substituting the original
-- variable through the delete-at-n environment.
--   sem_lookup_d d (ins a n g) t (shift a g t v n) env
--     = sem_lookup_d d g t v (del a n g d env)
-- This is the Var case of the weaken-subst commutation. indrec Var, natrec on
-- n: refl in both here sub-cases and the there/zero sub-case; the Var-IH at
-- cutoff m in there/succ. No J.

:let sdl = (\a. \g. \t. \v. indrec Var (\g1. \t1. \v1. Π(n : Nat). Π(d : Ctx). Π(env : SemCtx_d d (ins a n g1)). Id (Expr d t1) (sem_lookup_d d (ins a n g1) t1 (shift a g1 t1 v1 n) env) (sem_lookup_d d g1 t1 v1 (del a n g1 d env)) : Π(g1 : Ctx). Π(t1 : Ty). Var g1 t1 → Type) (\g1. \t1. \n. natrec (\n1. Π(d : Ctx). Π(env : SemCtx_d d (ins a n1 (ext t1 g1))). Id (Expr d t1) (sem_lookup_d d (ins a n1 (ext t1 g1)) t1 (shift a (ext t1 g1) t1 (here g1 t1) n1) env) (sem_lookup_d d (ext t1 g1) t1 (here g1 t1) (del a n1 (ext t1 g1) d env)) : Π(_ : Nat). Type) (\d. \env. refl (fst (snd env)) : Π(d : Ctx). Π(env : SemCtx_d d (ins a zero (ext t1 g1))). Id (Expr d t1) (sem_lookup_d d (ins a zero (ext t1 g1)) t1 (shift a (ext t1 g1) t1 (here g1 t1) zero) env) (sem_lookup_d d (ext t1 g1) t1 (here g1 t1) (del a zero (ext t1 g1) d env))) (\m. \ihn. \d. \env. refl (fst env) : Π(m : Nat). Π(ihn : Π(d : Ctx). Π(env : SemCtx_d d (ins a m (ext t1 g1))). Id (Expr d t1) (sem_lookup_d d (ins a m (ext t1 g1)) t1 (shift a (ext t1 g1) t1 (here g1 t1) m) env) (sem_lookup_d d (ext t1 g1) t1 (here g1 t1) (del a m (ext t1 g1) d env))). Π(d : Ctx). Π(env : SemCtx_d d (ins a (succ m) (ext t1 g1))). Id (Expr d t1) (sem_lookup_d d (ins a (succ m) (ext t1 g1)) t1 (shift a (ext t1 g1) t1 (here g1 t1) (succ m)) env) (sem_lookup_d d (ext t1 g1) t1 (here g1 t1) (del a (succ m) (ext t1 g1) d env))) n : Π(g1 : Ctx). Π(t1 : Ty). Π(n : Nat). Π(d : Ctx). Π(env : SemCtx_d d (ins a n (ext t1 g1))). Id (Expr d t1) (sem_lookup_d d (ins a n (ext t1 g1)) t1 (shift a (ext t1 g1) t1 (here g1 t1) n) env) (sem_lookup_d d (ext t1 g1) t1 (here g1 t1) (del a n (ext t1 g1) d env))) (\g1. \t1. \s. \v1. \ihv. \n. natrec (\n1. Π(d : Ctx). Π(env : SemCtx_d d (ins a n1 (ext s g1))). Id (Expr d t1) (sem_lookup_d d (ins a n1 (ext s g1)) t1 (shift a (ext s g1) t1 (there g1 t1 s v1) n1) env) (sem_lookup_d d (ext s g1) t1 (there g1 t1 s v1) (del a n1 (ext s g1) d env)) : Π(_ : Nat). Type) (\d. \env. refl (sem_lookup_d d g1 t1 v1 (snd (snd env))) : Π(d : Ctx). Π(env : SemCtx_d d (ins a zero (ext s g1))). Id (Expr d t1) (sem_lookup_d d (ins a zero (ext s g1)) t1 (shift a (ext s g1) t1 (there g1 t1 s v1) zero) env) (sem_lookup_d d (ext s g1) t1 (there g1 t1 s v1) (del a zero (ext s g1) d env))) (\m. \ihn. \d. \env. ihv m d (snd env) : Π(m : Nat). Π(ihn : Π(d : Ctx). Π(env : SemCtx_d d (ins a m (ext s g1))). Id (Expr d t1) (sem_lookup_d d (ins a m (ext s g1)) t1 (shift a (ext s g1) t1 (there g1 t1 s v1) m) env) (sem_lookup_d d (ext s g1) t1 (there g1 t1 s v1) (del a m (ext s g1) d env))). Π(d : Ctx). Π(env : SemCtx_d d (ins a (succ m) (ext s g1))). Id (Expr d t1) (sem_lookup_d d (ins a (succ m) (ext s g1)) t1 (shift a (ext s g1) t1 (there g1 t1 s v1) (succ m)) env) (sem_lookup_d d (ext s g1) t1 (there g1 t1 s v1) (del a (succ m) (ext s g1) d env))) n : Π(g1 : Ctx). Π(t1 : Ty). Π(s : Ty). Π(v1 : Var g1 t1). (Π(n : Nat). Π(d : Ctx). Π(env : SemCtx_d d (ins a n g1)). Id (Expr d t1) (sem_lookup_d d (ins a n g1) t1 (shift a g1 t1 v1 n) env) (sem_lookup_d d g1 t1 v1 (del a n g1 d env))) → Π(n : Nat). Π(d : Ctx). Π(env : SemCtx_d d (ins a n (ext s g1))). Id (Expr d t1) (sem_lookup_d d (ins a n (ext s g1)) t1 (shift a (ext s g1) t1 (there g1 t1 s v1) n) env) (sem_lookup_d d (ext s g1) t1 (there g1 t1 s v1) (del a n (ext s g1) d env))) v : Π(a : Ty). Π(g : Ctx). Π(t : Ty). Π(v : Var g t). Π(n : Nat). Π(d : Ctx). Π(env : SemCtx_d d (ins a n g)). Id (Expr d t) (sem_lookup_d d (ins a n g) t (shift a g t v n) env) (sem_lookup_d d g t v (del a n g d env)))
:i sdl

-- ── Id congruence toolkit (J-based) ───────────────────────────────────────────
-- ap/trans/ap2/ap3 lift equalities under a function / compose them.  Generic,
-- needed by the compound (App/If/Let/Lam) cases of GenCancel below.  Each is a
-- one-liner over J; they compute to refl on refl inputs.

:let ap = (\A. \B. \f. \x. \y. \p. J A x (\y1. \p1. Id B (f x) (f y1) : Π(y1 : A). Id A x y1 → Type) (refl (f x)) y p : Π(A : Type). Π(B : Type). Π(f : A → B). Π(x : A). Π(y : A). Id A x y → Id B (f x) (f y))

:let trans = (\A. \x. \y. \z. \p. \q. J A y (\z1. \q1. Id A x z1 : Π(z1 : A). Id A y z1 → Type) p z q : Π(A : Type). Π(x : A). Π(y : A). Π(z : A). Id A x y → Id A y z → Id A x z)

:let ap2 = (\A. \B. \C. \f. \x. \x1. \y. \y1. \p. \q. trans C (f x y) (f x1 y) (f x1 y1) (ap A C (\z. f z y) x x1 p) (ap B C (\z. f x1 z) y y1 q) : Π(A : Type). Π(B : Type). Π(C : Type). Π(f : A → B → C). Π(x : A). Π(x1 : A). Π(y : B). Π(y1 : B). Id A x x1 → Id B y y1 → Id C (f x y) (f x1 y1))

:let ap3 = (\A. \B. \C. \D. \f. \x. \x1. \y. \y1. \z. \z1. \p. \q. \r. trans D (f x y z) (f x1 y1 z) (f x1 y1 z1) (ap2 A B D (\u. \w. f u w z) x x1 y y1 p q) (ap C D (\w. f x1 y1 w) z z1 r) : Π(A : Type). Π(B : Type). Π(C : Type). Π(D : Type). Π(f : A → B → C → D). Π(x : A). Π(x1 : A). Π(y : B). Π(y1 : B). Π(z : C). Π(z1 : C). Id A x x1 → Id B y y1 → Id C z z1 → Id D (f x y z) (f x1 y1 z1))

-- ── del_wk : del commutes with weaken_semctx_d ────────────────────────────────
--   del a n g (ext a1 d) (weaken_semctx_d a1 d (ins a n g) env)
--     = weaken_semctx_d a1 d g (del a n g d env)
-- Deleting the cutoff-n entry and inserting a new output binding commute.  Needed
-- by the ELam case of GenCancel (its body weakens the env on both sides).
-- natrec on n + indrec Ctx on g: refl at zero and (succ, empty); ap of the
-- natrec-IH at (succ, ext).

:let del_wk = (\a. \a1. \n. natrec (\n1. Π(g : Ctx). Π(d : Ctx). Π(env : SemCtx_d d (ins a n1 g)). Id (SemCtx_d (ext a1 d) g) (del a n1 g (ext a1 d) (weaken_semctx_d a1 d (ins a n1 g) env)) (weaken_semctx_d a1 d g (del a n1 g d env)) : Π(_ : Nat). Type) (\g. \d. \env. refl (weaken_semctx_d a1 d g (snd env)) : Π(g : Ctx). Π(d : Ctx). Π(env : SemCtx_d d (ins a zero g)). Id (SemCtx_d (ext a1 d) g) (del a zero g (ext a1 d) (weaken_semctx_d a1 d (ins a zero g) env)) (weaken_semctx_d a1 d g (del a zero g d env))) (\m. \ihn. \g. \d. indrec Ctx (\g1. Π(env : SemCtx_d d (ins a (succ m) g1)). Id (SemCtx_d (ext a1 d) g1) (del a (succ m) g1 (ext a1 d) (weaken_semctx_d a1 d (ins a (succ m) g1) env)) (weaken_semctx_d a1 d g1 (del a (succ m) g1 d env)) : Ctx → Type) (\env. refl (weaken_semctx_d a1 d empty env) : Π(env : SemCtx_d d (ins a (succ m) empty)). Id (SemCtx_d (ext a1 d) empty) (del a (succ m) empty (ext a1 d) (weaken_semctx_d a1 d (ins a (succ m) empty) env)) (weaken_semctx_d a1 d empty (del a (succ m) empty d env))) (\s. \g1. \ihc. \env. ap (SemCtx_d (ext a1 d) g1) (SemCtx_d (ext a1 d) (ext s g1)) (\tl. (wk0 a1 d s (fst env), tl)) (del a m g1 (ext a1 d) (weaken_semctx_d a1 d (ins a m g1) (snd env))) (weaken_semctx_d a1 d g1 (del a m g1 d (snd env))) (ihn g1 d (snd env)) : Π(s : Ty). Π(g1 : Ctx). Π(ihc : Π(env : SemCtx_d d (ins a (succ m) g1)). Id (SemCtx_d (ext a1 d) g1) (del a (succ m) g1 (ext a1 d) (weaken_semctx_d a1 d (ins a (succ m) g1) env)) (weaken_semctx_d a1 d g1 (del a (succ m) g1 d env))). Π(env : SemCtx_d d (ins a (succ m) (ext s g1))). Id (SemCtx_d (ext a1 d) (ext s g1)) (del a (succ m) (ext s g1) (ext a1 d) (weaken_semctx_d a1 d (ins a (succ m) (ext s g1)) env)) (weaken_semctx_d a1 d (ext s g1) (del a (succ m) (ext s g1) d env))) g : Π(m : Nat). Π(ihn : Π(g : Ctx). Π(d : Ctx). Π(env : SemCtx_d d (ins a m g)). Id (SemCtx_d (ext a1 d) g) (del a m g (ext a1 d) (weaken_semctx_d a1 d (ins a m g) env)) (weaken_semctx_d a1 d g (del a m g d env))). Π(g : Ctx). Π(d : Ctx). Π(env : SemCtx_d d (ins a (succ m) g)). Id (SemCtx_d (ext a1 d) g) (del a (succ m) g (ext a1 d) (weaken_semctx_d a1 d (ins a (succ m) g) env)) (weaken_semctx_d a1 d g (del a (succ m) g d env))) n : Π(a : Ty). Π(a1 : Ty). Π(n : Nat). Π(g : Ctx). Π(d : Ctx). Π(env : SemCtx_d d (ins a n g)). Id (SemCtx_d (ext a1 d) g) (del a n g (ext a1 d) (weaken_semctx_d a1 d (ins a n g) env)) (weaken_semctx_d a1 d g (del a n g d env)))
:i del_wk

-- ── GenCancel : weaken/substitute commutation (the big brick, indrec Expr) ─────
--   sub_open (ins a n g) t (wk a g t e n) d env = sub_open g t e d (del a n g d env)
-- Substituting into a weakened term equals substituting into the original under
-- the environment with the inserted entry deleted.  By indrec Expr on e:
--   literals = refl ; EVar = sdl ; EApp = ap2 ; EIf = ap3 ;
--   ELam = ap(ELam)∘trans of (body-IH at succ n) and (del_wk under the env) ;
--   ELet = trans of (body-IH at succ n) and (ap of the value-IH in the env head).
-- This is the last piece before the σ-fusion assembly (brick 3).

:let GenCancel = (\a. \g. \t. \e. indrec Expr (\g1. \t1. \e1. Π(n : Nat). Π(d : Ctx). Π(env : SemCtx_d d (ins a n g1)). Id (Expr d t1) (sub_open (ins a n g1) t1 (wk a g1 t1 e1 n) d env) (sub_open g1 t1 e1 d (del a n g1 d env)) : Π(g1 : Ctx). Π(t1 : Ty). Π(e1 : Expr g1 t1). Type) (\g1. \m. \n. \d. \env. refl (ELitInt d m) : Π(g1 : Ctx). Π(m : Nat). Π(n : Nat). Π(d : Ctx). Π(env : SemCtx_d d (ins a n g1)). Id (Expr d TInt) (sub_open (ins a n g1) TInt (wk a g1 TInt (ELitInt g1 m) n) d env) (sub_open g1 TInt (ELitInt g1 m) d (del a n g1 d env))) (\g1. \n. \d. \env. refl (ELitFlt d) : Π(g1 : Ctx). Π(n : Nat). Π(d : Ctx). Π(env : SemCtx_d d (ins a n g1)). Id (Expr d TFloat) (sub_open (ins a n g1) TFloat (wk a g1 TFloat (ELitFlt g1) n) d env) (sub_open g1 TFloat (ELitFlt g1) d (del a n g1 d env))) (\g1. \b. \n. \d. \env. refl (ELitBool d b) : Π(g1 : Ctx). Π(b : Bool). Π(n : Nat). Π(d : Ctx). Π(env : SemCtx_d d (ins a n g1)). Id (Expr d TBool) (sub_open (ins a n g1) TBool (wk a g1 TBool (ELitBool g1 b) n) d env) (sub_open g1 TBool (ELitBool g1 b) d (del a n g1 d env))) (\g1. \n. \d. \env. refl (ELitStr d) : Π(g1 : Ctx). Π(n : Nat). Π(d : Ctx). Π(env : SemCtx_d d (ins a n g1)). Id (Expr d TStr) (sub_open (ins a n g1) TStr (wk a g1 TStr (ELitStr g1) n) d env) (sub_open g1 TStr (ELitStr g1) d (del a n g1 d env))) (\g1. \n. \d. \env. refl (EUnit d) : Π(g1 : Ctx). Π(n : Nat). Π(d : Ctx). Π(env : SemCtx_d d (ins a n g1)). Id (Expr d TUnit) (sub_open (ins a n g1) TUnit (wk a g1 TUnit (EUnit g1) n) d env) (sub_open g1 TUnit (EUnit g1) d (del a n g1 d env))) (\g1. \t1. \v1. \n. \d. \env. sdl a g1 t1 v1 n d env : Π(g1 : Ctx). Π(t1 : Ty). Π(v1 : Var g1 t1). Π(n : Nat). Π(d : Ctx). Π(env : SemCtx_d d (ins a n g1)). Id (Expr d t1) (sub_open (ins a n g1) t1 (wk a g1 t1 (EVar g1 t1 v1) n) d env) (sub_open g1 t1 (EVar g1 t1 v1) d (del a n g1 d env))) (\g1. \a1. \b1. \bd. \ihbd. \n. \d. \env. ap (Expr (ext a1 d) b1) (Expr d (TFn a1 b1)) (\bb. ELam d a1 b1 bb) (sub_open (ins a (succ n) (ext a1 g1)) b1 (wk a (ext a1 g1) b1 bd (succ n)) (ext a1 d) (EVar (ext a1 d) a1 (here d a1), weaken_semctx_d a1 d (ins a n g1) env)) (sub_open (ext a1 g1) b1 bd (ext a1 d) (EVar (ext a1 d) a1 (here d a1), weaken_semctx_d a1 d g1 (del a n g1 d env))) (trans (Expr (ext a1 d) b1) (sub_open (ins a (succ n) (ext a1 g1)) b1 (wk a (ext a1 g1) b1 bd (succ n)) (ext a1 d) (EVar (ext a1 d) a1 (here d a1), weaken_semctx_d a1 d (ins a n g1) env)) (sub_open (ext a1 g1) b1 bd (ext a1 d) (EVar (ext a1 d) a1 (here d a1), del a n g1 (ext a1 d) (weaken_semctx_d a1 d (ins a n g1) env))) (sub_open (ext a1 g1) b1 bd (ext a1 d) (EVar (ext a1 d) a1 (here d a1), weaken_semctx_d a1 d g1 (del a n g1 d env))) (ihbd (succ n) (ext a1 d) (EVar (ext a1 d) a1 (here d a1), weaken_semctx_d a1 d (ins a n g1) env)) (ap (SemCtx_d (ext a1 d) g1) (Expr (ext a1 d) b1) (\tl. sub_open (ext a1 g1) b1 bd (ext a1 d) (EVar (ext a1 d) a1 (here d a1), tl)) (del a n g1 (ext a1 d) (weaken_semctx_d a1 d (ins a n g1) env)) (weaken_semctx_d a1 d g1 (del a n g1 d env)) (del_wk a a1 n g1 d env))) : Π(g1 : Ctx). Π(a1 : Ty). Π(b1 : Ty). Π(bd : Expr (ext a1 g1) b1). Π(ihbd : Π(n : Nat). Π(d : Ctx). Π(env : SemCtx_d d (ins a n (ext a1 g1))). Id (Expr d b1) (sub_open (ins a n (ext a1 g1)) b1 (wk a (ext a1 g1) b1 bd n) d env) (sub_open (ext a1 g1) b1 bd d (del a n (ext a1 g1) d env))). Π(n : Nat). Π(d : Ctx). Π(env : SemCtx_d d (ins a n g1)). Id (Expr d (TFn a1 b1)) (sub_open (ins a n g1) (TFn a1 b1) (wk a g1 (TFn a1 b1) (ELam g1 a1 b1 bd) n) d env) (sub_open g1 (TFn a1 b1) (ELam g1 a1 b1 bd) d (del a n g1 d env))) (\g1. \a1. \b1. \f. \ihf. \x. \ihx. \n. \d. \env. ap2 (Expr d (TFn a1 b1)) (Expr d a1) (Expr d b1) (EApp d a1 b1) (sub_open (ins a n g1) (TFn a1 b1) (wk a g1 (TFn a1 b1) f n) d env) (sub_open g1 (TFn a1 b1) f d (del a n g1 d env)) (sub_open (ins a n g1) a1 (wk a g1 a1 x n) d env) (sub_open g1 a1 x d (del a n g1 d env)) (ihf n d env) (ihx n d env) : Π(g1 : Ctx). Π(a1 : Ty). Π(b1 : Ty). Π(f : Expr g1 (TFn a1 b1)). Π(ihf :