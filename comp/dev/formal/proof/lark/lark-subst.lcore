(Expr d2 t1) (sub_open d1 t1 (sub_open g1 t1 (EVar g1 t1 v1) d1 env1) d2 env2) (sub_open g1 t1 (EVar g1 t1 v1) d2 (comp d1 d2 env2 g1 env1))) (\g1. \a1. \b1. \bd. \ihbd. \d1. \d2. \env1. \env2. ap (Expr (ext a1 d2) b1) (Expr d2 (TFn a1 b1)) (\bb. ELam d2 a1 b1 bb) (sub_open (ext a1 d1) b1 (sub_open (ext a1 g1) b1 bd (ext a1 d1) (EVar (ext a1 d1) a1 (here d1 a1), weaken_semctx_d a1 d1 g1 env1)) (ext a1 d2) (EVar (ext a1 d2) a1 (here d2 a1), weaken_semctx_d a1 d2 d1 env2)) (sub_open (ext a1 g1) b1 bd (ext a1 d2) (EVar (ext a1 d2) a1 (here d2 a1), weaken_semctx_d a1 d2 g1 (comp d1 d2 env2 g1 env1))) (trans (Expr (ext a1 d2) b1) (sub_open (ext a1 d1) b1 (sub_open (ext a1 g1) b1 bd (ext a1 d1) (EVar (ext a1 d1) a1 (here d1 a1), weaken_semctx_d a1 d1 g1 env1)) (ext a1 d2) (EVar (ext a1 d2) a1 (here d2 a1), weaken_semctx_d a1 d2 d1 env2)) (sub_open (ext a1 g1) b1 bd (ext a1 d2) (comp (ext a1 d1) (ext a1 d2) (EVar (ext a1 d2) a1 (here d2 a1), weaken_semctx_d a1 d2 d1 env2) (ext a1 g1) (EVar (ext a1 d1) a1 (here d1 a1), weaken_semctx_d a1 d1 g1 env1))) (sub_open (ext a1 g1) b1 bd (ext a1 d2) (EVar (ext a1 d2) a1 (here d2 a1), weaken_semctx_d a1 d2 g1 (comp d1 d2 env2 g1 env1))) (ihbd (ext a1 d1) (ext a1 d2) (EVar (ext a1 d1) a1 (here d1 a1), weaken_semctx_d a1 d1 g1 env1) (EVar (ext a1 d2) a1 (here d2 a1), weaken_semctx_d a1 d2 d1 env2)) (ap (SemCtx_d (ext a1 d2) g1) (Expr (ext a1 d2) b1) (\tl. sub_open (ext a1 g1) b1 bd (ext a1 d2) (EVar (ext a1 d2) a1 (here d2 a1), tl)) (comp (ext a1 d1) (ext a1 d2) (EVar (ext a1 d2) a1 (here d2 a1), weaken_semctx_d a1 d2 d1 env2) g1 (weaken_semctx_d a1 d1 g1 env1)) (weaken_semctx_d a1 d2 g1 (comp d1 d2 env2 g1 env1)) (comp_weaken a1 d1 d2 env2 g1 env1))) : Π(g1 : Ctx). Π(a1 : Ty). Π(b1 : Ty). Π(bd : Expr (ext a1 g1) b1). Π(ihbd : Π(d1 : Ctx). Π(d2 : Ctx). Π(env1 : SemCtx_d d1 (ext a1 g1)). Π(env2 : SemCtx_d d2 d1). Id (Expr d2 b1) (sub_open d1 b1 (sub_open (ext a1 g1) b1 bd d1 env1) d2 env2) (sub_open (ext a1 g1) b1 bd d2 (comp d1 d2 env2