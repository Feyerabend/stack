d1 d2 env2 g1 env1))) (ihv d1 d2 env1 env2) (trans (Expr (ext a1 d2) b1) (sub_open (ext a1 d1) b1 (sub_open (ext a1 g1) b1 bd (ext a1 d1) (EVar (ext a1 d1) a1 (here d1 a1), weaken_semctx_d a1 d1 g1 env1)) (ext a1 d2) (EVar (ext a1 d2) a1 (here d2 a1), weaken_semctx_d a1 d2 d1 env2)) (sub_open (ext a1 g1) b1 bd (ext a1 d2) (comp (ext a1 d1) (ext a1 d2) (EVar (ext a1 d2) a1 (here d2 a1), weaken_semctx_d a1 d2 d1 env2) (ext a1 g1) (EVar (ext a1 d1) a1 (here d1 a1), weaken_semctx_d a1 d1 g1 env1))) (sub_open (ext a1 g1) b1 bd (ext a1 d2) (EVar (ext a1 d2) a1 (here d2 a1), weaken_semctx_d a1 d2 g1 (comp d1 d2 env2 g1 env1))) (ihbd (ext a1 d1) (ext a1 d2) (EVar (ext a1 d1) a1 (here d1 a1), weaken_semctx_d a1 d1 g1 env1) (EVar (ext a1 d2) a1 (here d2 a1), weaken_semctx_d a1 d2 d1 env2)) (ap (SemCtx_d (ext a1 d2) g1) (Expr (ext a1 d2) b1) (\tl. sub_open (ext a1 g1) b1 bd (ext a1 d2) (EVar (ext a1 d2) a1 (here d2 a1), tl)) (comp (ext a1 d1) (ext a1 d2) (EVar (ext a1 d2) a1 (here d2 a1), weaken_semctx_d a1 d2 d1 env2) g1 (weaken_semctx_d a1 d1 g1 env1)) (weaken_semctx_d a1 d2 g1 (comp d1 d2 env2 g1 env1)) (comp_weaken a1 d1 d2 env2 g1 env1))) : Π(g1 : Ctx). Π(a1 : Ty). Π(b1 : Ty). Π(val : Expr g1 a1). Π(ihv : Π(d1 : Ctx). Π(d2 : Ctx). Π(env1 : SemCtx_d d1 g1). Π(env2 : SemCtx_d d2 d1). Id (Expr d2 a1) (sub_open d1 a1 (sub_open g1 a1 val d1 env1) d2 env2) (sub_open g1 a1 val d2 (comp d1 d2 env2 g1 env1))). Π(bd : Expr (ext a1 g1) b1). Π(ihbd : Π(d1 : Ctx). Π(d2 : Ctx). Π(env1 : SemCtx_d d1 (ext a1 g1)). Π(env2 : SemCtx_d d2 d1). Id (Expr d2 b1) (sub_open d1 b1 (sub_open (ext a1 g1) b1 bd d1 env1) d2 env2) (sub_open (ext a1 g1) b1 bd d2 (comp d1 d2 env2 (ext a1 g1) env1))). Π(d1 : Ctx). Π(d2 : Ctx). Π(env1 : SemCtx_d d1 g1). Π(env2 : SemCtx_d d2 d1). Id (Expr d2 b1) (sub_open d1 b1 (sub_open g1 b1 (ELet g1 a1 b1 val bd) d1 env1) d2 env2) (sub_open g1 b1 (ELet g1 a1 b1 val bd) d2 (comp d1 d2 env2 g1 env1))) (\g1. \t1. \c. \ihc. \th. \ihth. \el. \ihel. \d1. \d2. \env1. \env2. ap3 (Expr d2 TBool) (Expr d2 t1) (Expr d2 t1) (Expr d2 t1) (EIf d2 t1) (sub_open d1 TBool (sub_open g1 TBool c d1 env1) d2 env2) (sub_open g1 TBool c d2 (comp d1 d2 env2 g1 env1)) (sub_open d1 t1 (sub_open g1 t1 th d1 env1) d2 env2) (sub_open g1 t1 th d2 (comp d1 d2 env2 g1 env1)) (sub_open d1 t1 (sub_open g1 t1 el d1 env1) d2 env2) (sub_open g1 t1 el d2 (comp d1 d2 env2 g1 env1)) (ihc d1 d2 env1 env2) (ihth d1 d2 env1 env2) (ihel d1 d2 env1 env2) : Π(g1 : Ctx). Π(t1 : Ty). Π(c : Expr g1 TBool). Π(ihc : Π(d1 : Ctx). Π(d2 : Ctx). Π(env1 : SemCtx_d d1 g1). Π(env2 : SemCtx_d d2 d1). Id (Expr d2 TBool) (sub_open d1 TBool (sub_open g1 TBool c d1 env1) d2 env2) (sub_open g1 TBool c d2 (comp d1 d2 env2 g1 env1))). Π(th : Expr g1 t1). Π(ihth : Π(d1 : Ctx). Π(d2 : Ctx). Π(env1 : SemCtx_d d1 g1). Π(env2 : SemCtx_d d2 d1). Id (Expr d2 t1) (sub_open d1 t1 (sub_open g1 t1 th d1 env1) d2 env2) (sub_open g1 t1 th d2 (comp d1 d2 env2 g1 env1))). Π(el : Expr g1 t1). Π(ihel : Π(d1 : Ctx). Π(d2 : Ctx). Π(env1 : SemCtx_d d1 g1). Π(env2 : SemCtx_d d2 d1). Id (Expr d2 t1) (sub_open d1 t1 (sub_open g1 t1 el d1 env1) d2 env2) (sub_open g1 t1 el d2 (comp d1 d2 env2 g1 env1))). Π(d1 : Ctx). Π(d2 : Ctx). Π(env1 : SemCtx_d d1 g1). Π(env2 : SemCtx_d d2 d1). Id (Expr d2 t1) (sub_open d1 t1 (sub_open g1 t1 (EIf g1 t1 c th el) d1 env1) d2 env2) (sub_open g1 t1 (EIf g1 t1 c th el) d2 (comp d1 d2 env2 g1 env1))) e : Π(g : Ctx). Π(t : Ty). Π(e : Expr g t). Π(d1 : Ctx). Π(d2 : Ctx). Π(env1 : SemCtx_d d1 g). Π(env2 : SemCtx_d d2 d1). Id (Expr d2 t) (sub_open d1 t (sub_open g t e d1 env1) d2 env2) (sub_open g t e d2 (comp d1 d2 env2 g env1)))
:i sub_sub

-- ── fuse : the β/let FUSION — (sub∘open-sub) with a value cancels to sub-under-(V,env) ─
-- ── = sub_sub instance ∘ comp_weaken_cancel; the shape RT_Lam/RT_Let contract to. ─────
:let fuse = (\a. \g. \b. \body. \V. \env. trans (Expr empty b) (sub_open (ext a empty) b (sub_open (ext a g) b body (ext a empty) (EVar (ext a empty) a (here empty a), weaken_semctx_d a empty g env)) empty (V, star)) (sub_open (ext a g) b body empty (comp (ext a empty) empty (V, star) (ext a g) (EVar (ext a empty) a (here empty a), weaken_semctx_d a empty g env))) (sub_open (ext a g) b body empty (V, env)) (sub_sub (ext a g) b body (ext a empty) empty (EVar (ext a empty) a (here empty a), weaken_semctx_d a empty g env) (V, star)) (ap (SemCtx_d empty (ext a g)) (Expr empty b) (\ee. sub_open (ext a g) b body empty ee) (comp (ext a empty) empty (V, star) (ext a g) (EVar (ext a empty) a (here empty a), weaken_semctx_d a empty g env)) (V, env) (ap (SemCtx_d empty g) (SemCtx_d empty (ext a g)) (\tl. (V, tl)) (comp (ext a empty) empty (V, star) g (weaken_semctx_d a empty g env)) env (comp_weaken_cancel a V g env))) : Π(a : Ty). Π(g : Ctx). Π(b : Ty). Π(body : Expr (ext a g) b). Π(V : Expr empty a). Π(env : SemCtx_d empty g). Id (Expr empty b) (sub_open (ext a empty) b (sub_open (ext a g) b body (ext a empty) (EVar (ext a empty) a (here empty a), weaken_semctx_d a empty g env)) empty (V, star)) (sub_open (ext a g) b body empty (V, env)))
:i fuse

-- ── IsVal : closed-value predicate ────────────────────────────────────────────
-- IsVal t e  holds when e : Expr empty t  is already a value.
-- Mirrors cek.py is_whnf / is_value checks.
--
-- Values: literal integers, floats, booleans, strings, unit, and lambdas.
-- Variables can never be values (Var empty t is uninhabited).
-- EApp, ELet, EIf, EVar are never values — they need to step.

data IsVal : Π(t : Ty). Expr empty t → Type where ValInt : Π(n : Nat). IsVal TInt (ELitInt empty n) ; ValFlt : IsVal TFloat (ELitFlt empty) ; ValBool : Π(b : Bool). IsVal TBool (ELitBool empty b) ; ValStr : IsVal TStr (ELitStr empty) ; ValUnit : IsVal TUnit (EUnit empty) ; ValLam : Π(a : Ty). Π(b : Ty). Π(body : Expr (ext a empty) b). IsVal (TFn a b) (ELam empty a b body)

-- ── Smoke tests ────────────────────────────────────────────────────────────────

-- SemCtx normalises as expected
:i SemCtx

-- sem_lookup: retrieve first variable from a two-binding environment
-- Γ = ext TInt (ext TBool empty),  env = (ELitInt empty 2, ELitBool empty true, star)
:let env_ib = ((ELitInt empty (succ (succ zero)), (ELitBool empty true, star)) : SemCtx (ext TInt (ext TBool empty)))
:let v_int  = (here (ext TBool empty) TInt : Var (ext TInt (ext TBool empty)) TInt)
:let v_bool = (there (ext TBool empty) TBool TInt (here empty TBool) : Var (ext TInt (ext TBool empty)) TBool)
(sem_lookup (ext TInt (ext TBool empty)) TInt  v_int  env_ib)
(sem_lookup (ext TInt (ext TBool empty)) TBool v_bool env_ib)

-- dummy_expr produces canonical terms
(dummy_expr TBool empty)
(dummy_expr (TFn TInt TBool) empty)

-- sub_ground: substitute ELitInt for the single variable in simple terms
-- Γ = ext TInt empty,  env = (ELitInt empty 2, star)
:let env_i = ((ELitInt empty (succ (succ zero)), star) : SemCtx (ext TInt empty))

-- x  [x := 2]  =  2
(sub_ground (ext TInt empty) TInt (EVar (ext TInt empty) TInt (here empty TInt)) env_i)

-- true  [x := 2]  =  true   (literal doesn't mention x)
(sub_ground (ext TInt empty) TBool (ELitBool (ext TInt empty) true) env_i)

-- if true then x else x  [x := 2]  =  if true then 2 else 2
(sub_ground (ext TInt empty) TInt (EIf (ext TInt empty) TInt (ELitBool (ext TInt empty) true) (EVar (ext TInt empty) TInt (here empty TInt)) (EVar (ext TInt empty) TInt (here empty TInt))) env_i)

-- let y : Bool = true in y  [x := 2]  =  let y = true in y
-- (substitution is HOMOMORPHIC: the ELet node survives — x does not occur, so
--  the let is unchanged; reducing it is StepLetBeta's job, not substitution's)
(sub_ground (ext TInt empty) TBool (ELet (ext TInt empty) TBool TBool (ELitBool (ext TInt empty) true) (EVar (ext TBool (ext TInt empty)) TBool (here (ext TInt empty) TBool))) env_i)

-- sub_ground: EApp case
-- Γ = ext (TFn TBool TBool) (ext TBool empty)
-- env maps: innermost → identity fn, outer → true
-- Expr: (f : TFn TBool TBool) applied to (b : TBool)
-- Expected: EApp empty TBool TBool <identity> (ELitBool empty true)
:let env_fb = ((ELam empty TBool TBool (EVar (ext TBool empty) TBool (here empty TBool)), (ELitBool empty true, star)) : SemCtx (ext (TFn TBool TBool) (ext TBool empty)))
:let v_f = (here (ext TBool empty) (TFn TBool TBool) : Var (ext (TFn TBool TBool) (ext TBool empty)) (TFn TBool TBool))
:let v_b = (there (ext TBool empty) TBool (TFn TBool TBool) (here empty TBool) : Var (ext (TFn TBool TBool) (ext TBool empty)) TBool)
:let eapp_fv = (EApp (ext (TFn TBool TBool) (ext TBool empty)) TBool TBool (EVar (ext (TFn TBool TBool) (ext TBool empty)) (TFn TBool TBool) v_f) (EVar (ext (TFn TBool TBool) (ext TBool empty)) TBool v_b) : Expr (ext (TFn TBool TBool) (ext TBool empty)) TBool)
(sub_ground (ext (TFn TBool TBool) (ext TBool empty)) TBool eapp_fv env_fb)

-- sub_ground: ELam case — NOW CORRECT (no longer returns dummy_expr)
-- Γ = ext TInt empty,  Expr: λ(b : Bool). true  (constant fn ignoring x)
-- Expected: ELam empty TBool TBool (ELitBool (ext TBool empty) true)
:let elam_const = (ELam (ext TInt empty) TBool TBool (ELitBool (ext TBool (ext TInt empty)) true) : Expr (ext TInt empty) (TFn TBool TBool))
(sub_ground (ext TInt empty) (TFn TBool TBool) elam_const env_i)

-- sub_ground: ELam case with variable use — THE KEY FIX
-- Γ = ext TInt empty,  Expr: λ(b : Bool). b  (identity lambda, ignores x)
-- Expected: ELam empty TBool TBool (EVar (ext TBool empty) TBool (here empty TBool))
--   (lambda param stays as a variable in the weakened context)
:let elam_id = (ELam (ext TInt empty) TBool TBool (EVar (ext TBool (ext TInt empty)) TBool (here (ext TInt empty) TBool)) : Expr (ext TInt empty) (TFn TBool TBool))
(sub_ground (ext TInt empty) (TFn TBool TBool) elam_id env_i)

-- weaken smoke tests (kernel primitive)
-- weaken TBool empty TInt (ELitInt empty 1) = ELitInt (ext TBool empty) 1
-- (payload must pass through weaken untouched — only the context arg shifts)
:let wk1 = (weaken TBool empty TInt (ELitInt empty (succ zero)) : Expr (ext TBool empty) TInt)
:i wk1
-- weaken TInt (ext TBool empty) TBool (EVar ...) shifts the variable
:let wk2 = (weaken TInt (ext TBool empty) TBool (EVar (ext TBool empty) TBool (here empty TBool)) : Expr (ext TInt (ext TBool empty)) TBool)
:i wk2

-- AGREEMENT with the kernel primitive on a payload-only tree (no Var): wk0
-- computes to the SAME normal form, so the rebase is conservative here.
:let wk0_agree_lit = (refl wk1 : Id (Expr (ext TBool empty) TInt) wk1 (wk0 TBool empty TInt (ELitInt empty (succ zero))))
:i wk0_agree_lit
-- NOTE: wk0 SUPERSEDES rather than mirrors the kernel weaken on the Var case.
-- Front-insert (ins a zero g = ext a g) must send index 0 → index 1, i.e.
-- here empty TBool ↦ there (ext TBool empty) TBool TInt (here empty TBool).
-- wk0 gives exactly this; the kernel weaken prints a there-node carrying the
-- wrong sub-context (empty). We keep wk0's answer and check its own typing:
:let wk0_var = (wk0 TInt (ext TBool empty) TBool (EVar (ext TBool empty) TBool (here empty TBool)) : Expr (ext TInt (ext TBool empty)) TBool)
:i wk0_var
-- and under a binder (cutoff climbs to 1, exercising the ELam case):
:let wk0_lam = (wk0 TInt empty (TFn TBool TBool) (ELam empty TBool TBool (EVar (ext TBool empty) TBool (here empty TBool))) : Expr (ext TInt empty) (TFn TBool TBool))
:i wk0_lam

-- IsVal witnesses — all 6 constructors
:let vval_int  = (ValInt (succ zero) : IsVal TInt (ELitInt empty (succ zero)))
:let vval_flt  = (ValFlt : IsVal TFloat (ELitFlt empty))
:let vval_bool_t = (ValBool true : IsVal TBool (ELitBool empty true))
:let vval_bool_f = (ValBool false : IsVal TBool (ELitBool empty false))
:let vval_str  = (ValStr : IsVal TStr (ELitStr empty))
:let vval_unit = (ValUnit : IsVal TUnit (EUnit empty))
:let vval_lam  = (ValLam TBool TBool (EVar (ext TBool empty) TBool (here empty TBool)) : IsVal (TFn TBool TBool) (ELam empty TBool TBool (EVar (ext TBool empty) TBool (here empty TBool))))
:i vval_int
:i vval_flt
:i vval_bool_t
:i vval_bool_f
:i vval_str
:i vval_unit
:i vval_lam
