-- ── comp / comp_lookup : composition of substitutions ─────────────────────────
-- comp d1 d2 env2 g env1 : SemCtx_d d2 g  — compose two substitution environments.
-- Maps each entry X : Expr d1 t of env1 to  sub_open d1 t X d2 env2 : Expr d2 t.
-- Foundations of the composition lemma sub_sub (needed for RT_Lam/RT_Let's fusion).
:let comp = (\d1. \d2. \env2. \g. indrec Ctx (\g1. SemCtx_d d1 g1 → SemCtx_d d2 g1 : Ctx → Type) (\e1. star : SemCtx_d d1 empty → SemCtx_d d2 empty) (\t. \g1. \ih. \e1. (sub_open d1 t (fst e1) d2 env2, ih (snd e1)) : Π(t : Ty). Π(g1 : Ctx). (SemCtx_d d1 g1 → SemCtx_d d2 g1) → SemCtx_d d1 (ext t g1) → SemCtx_d d2 (ext t g1)) g : Π(d1 : Ctx). Π(d2 : Ctx). Π(env2 : SemCtx_d d2 d1). Π(g : Ctx). SemCtx_d d1 g → SemCtx_d d2 g)
:i comp

-- comp_lookup: lookup commutes with comp.  refl (here) + IH (there), no J.
:let comp_lookup = (\g. \t. \v. indrec Var (\g1. \t1. \v1. Π(d1 : Ctx). Π(d2 : Ctx). Π(env1 : SemCtx_d d1 g1). Π(env2 : SemCtx_d d2 d1). Id (Expr d2 t1) (sub_open d1 t1 (sem_lookup_d d1 g1 t1 v1 env1) d2 env2) (sem_lookup_d d2 g1 t1 v1 (comp d1 d2 env2 g1 env1)) : Π(g1 : Ctx). Π(t1 : Ty). Var g1 t1 → Type) (\g1. \t1. \d1. \d2. \env1. \env2. refl (sub_open d1 t1 (fst env1) d2 env2) : Π(g1 : Ctx). Π(t1 : Ty). Π(d1 : Ctx). Π(d2 : Ctx). Π(env1 : SemCtx_d d1 (ext t1 g1)). Π(env2 : SemCtx_d d2 d1). Id (Expr d2 t1) (sub_open d1 t1 (sem_lookup_d d1 (ext t1 g1) t1 (here g1 t1) env1) d2 env2) (sem_lookup_d d2 (ext t1 g1) t1 (here g1 t1) (comp d1 d2 env2 (ext t1 g1) env1))) (\g1. \t1. \s. \v1. \ih. \d1. \d2. \env1. \env2. ih d1 d2 (snd env1) env2 : Π(g1 : Ctx). Π(t1 : Ty). Π(s : Ty). Π(v1 : Var g1 t1). (Π(d1 : Ctx). Π(d2 : Ctx). Π(env1 : SemCtx_d d1 g1). Π(env2 : SemCtx_d d2 d1). Id (Expr d2 t1) (sub_open d1 t1 (sem_lookup_d d1 g1 t1 v1 env1) d2 env2) (sem_lookup_d d2 g1 t1 v1 (comp d1 d2 env2 g1 env1))) → Π(d1 : Ctx). Π(d2 : Ctx). Π(env1 : SemCtx_d d1 (ext s g1)). Π(env2 : SemCtx_d d2 d1). Id (Expr d2 t1) (sub_open d1 t1 (sem_lookup_d d1 (ext s g1) t1 (there g1 t1 s v1) env1) d2 env2) (sem_lookup_d d2 (ext s g1) t1 (there g1 t1 s v1) (comp d1 d2 env2 (ext s g1) env1))) v : Π(g : Ctx). Π(t : Ty). Π(v : Var g t). Π(d1 : Ctx). Π(d2 : Ctx). Π(env1 : SemCtx_d d1 g). Π(env2 : SemCtx_d d2 d1). Id (Expr d2 t) (sub_open d1 t (sem_lookup_d d1 g t v env1) d2 env2) (sem_lookup_d d2 g t v (comp d1 d2 env2 g env1)))
:i comp_lookup

-- ── id_env / idsub : the identity substitution ────────────────────────────────
-- id_env g : SemCtx_d g g  — maps each variable to itself (EVar v).
:let id_env = (\g. indrec Ctx (\g1. SemCtx_d g1 g1 : Ctx → Type) (star : SemCtx_d empty empty) (\a. \g1. \ih. (EVar (ext a g1) a (here g1 a), weaken_semctx_d a g1 g1 ih) : Π(a : Ty). Π(g1 : Ctx). SemCtx_d g1 g1 → SemCtx_d (ext a g1) (ext a g1)) g : Π(g : Ctx). SemCtx_d g g)
:i id_env

-- shift_zero: inserting at cutoff 0 is just 'there'.  Both indrec-Var cases are refl (natrec base).
:let shift_zero = (\a. \g. \t. \v. indrec Var (\g1. \t1. \v1. Id (Var (ext a g1) t1) (shift a g1 t1 v1 zero) (there g1 t1 a v1) : Π(g1 : Ctx). Π(t1 : Ty). Var g1 t1 → Type) (\g1. \t1. refl (there (ext t1 g1) t1 a (here g1 t1)) : Π(g1 : Ctx). Π(t1 : Ty). Id (Var (ext a (ext t1 g1)) t1) (shift a (ext t1 g1) t1 (here g1 t1) zero) (there (ext t1 g1) t1 a (here g1 t1))) (\g1. \t1. \s. \v1. \ih. refl (there (ext s g1) t1 a (there g1 t1 s v1)) : Π(g1 : Ctx). Π(t1 : Ty). Π(s : Ty). Π(v1 : Var g1 t1). Id (Var (ext a g1) t1) (shift a g1 t1 v1 zero) (there g1 t1 a v1) → Id (Var (ext a (ext s g1)) t1) (shift a (ext s g1) t1 (there g1 t1 s v1) zero) (there (ext s g1) t1 a (there g1 t1 s v1))) v : Π(a : Ty). Π(g : Ctx). Π(t : Ty). Π(v : Var g t). Id (Var (ext a g) t) (shift a g t v zero) (there g t a v))
:i shift_zero

-- id_lookup: looking up v in the identity env returns EVar v.  here=refl; there via wk_lookup + shift_zero.
:let id_lookup = (\g. \t. \v. indrec Var (\g1. \t1. \v1. Id (Expr g1 t1) (sem_lookup_d g1 g1 t1 v1 (id_env g1)) (EVar g1 t1 v1) : Π(g1 : Ctx). Π(t1 : Ty). Var g1 t1 → Type) (\g1. \t1. refl (EVar (ext t1 g1) t1 (here g1 t1)) : Π(g1 : Ctx). Π(t1 : Ty). Id (Expr (ext t1 g1) t1) (sem_lookup_d (ext t1 g1) (ext t1 g1) t1 (here g1 t1) (id_env (ext t1 g1))) (EVar (ext t1 g1) t1 (here g1 t1))) (\g1. \t1. \s. \v1. \ih. trans (Expr (ext s g1) t1) (sem_lookup_d (ext s g1) g1 t1 v1 (weaken_semctx_d s g1 g1 (id_env g1))) (wk0 s g1 t1 (sem_lookup_d g1 g1 t1 v1 (id_env g1))) (EVar (ext s g1) t1 (there g1 t1 s v1)) (wk_lookup s g1 t1 v1 g1 (id_env g1)) (trans (Expr (ext s g1) t1) (wk0 s g1 t1 (sem_lookup_d g1 g1 t1 v1 (id_env g1))) (wk0 s g1 t1 (EVar g1 t1 v1)) (EVar (ext s g1) t1 (there g1 t1 s v1)) (ap (Expr g1 t1) (Expr (ext s g1) t1) (\z. wk0 s g1 t1 z) (sem_lookup_d g1 g1 t1 v1 (id_env g1)) (EVar g1 t1 v1) ih) (ap (Var (ext s g1) t1) (Expr (ext s g1) t1) (\vv. EVar (ext s g1) t1 vv) (shift s g1 t1 v1 zero) (there g1 t1 s v1) (shift_zero s g1 t1 v1))) : Π(g1 : Ctx). Π(t1 : Ty). Π(s : Ty). Π(v1 : Var g1 t1). Id (Expr g1 t1) (sem_lookup_d g1 g1 t1 v1 (id_env g1)) (EVar g1 t1 v1) → Id (Expr (ext s g1) t1) (sem_lookup_d (ext s g1) (ext s g1) t1 (there g1 t1 s v1) (id_env (ext s g1))) (EVar (ext s g1) t1 (there g1 t1 s v1))) v : Π(g : Ctx). Π(t : Ty). Π(v : Var g t). Id (Expr g t) (sem_lookup_d g g t v (id_env g)) (EVar g t v))
:i id_lookup

-- idsub: substituting by the identity env is the identity.  Binder case is DEFINITIONAL
-- (id_env (ext a g) is exactly the env sub_open builds under a binder).
:let idsub = (\g. \t. \e. indrec Expr (\g1. \t1. \e1. Id (Expr g1 t1) (sub_open g1 t1 e1 g1 (id_env g1)) e1 : Π(g1 : Ctx). Π(t1 : Ty). Expr g1 t1 → Type) (\g1. \m. refl (ELitInt g1 m) : Π(g1 : Ctx). Π(m : Nat). Id (Expr g1 TInt) (sub_open g1 TInt (ELitInt g1 m) g1 (id_env g1)) (ELitInt g1 m)) (\g1. refl (ELitFlt g1) : Π(g1 : Ctx). Id (Expr g1 TFloat) (sub_open g1 TFloat (ELitFlt g1) g1 (id_env g1)) (ELitFlt g1)) (\g1. \b. refl (ELitBool g1 b) : Π(g1 : Ctx). Π(b : Bool). Id (Expr g1 TBool) (sub_open g1 TBool (ELitBool g1 b) g1 (id_env g1)) (ELitBool g1 b)) (\g1. refl (ELitStr g1) : Π(g1 : Ctx). Id (Expr g1 TStr) (sub_open g1 TStr (ELitStr g1) g1 (id_env g1)) (ELitStr g1)) (\g1. refl (EUnit g1) : Π(g1 : Ctx). Id (Expr g1 TUnit) (sub_open g1 TUnit (EUnit g1) g1 (id_env g1)) (EUnit g1)) (\g1. \t1. \v1. id_lookup g1 t1 v1 : Π(g1 : Ctx). Π(t1 : Ty). Π(v1 : Var g1 t1). Id (Expr g1 t1) (sub_open g1 t1 (EVar g1 t1 v1) g1 (id_env g1)) (EVar g1 t1 v1)) (\g1. \a1. \b1. \bd. \ihbd. ap (Expr (ext a1 g1) b1) (Expr g1 (TFn a1 b1)) (\bb. ELam g1 a1 b1 bb) (sub_open (ext a1 g1) b1 bd (ext a1 g1) (id_env (ext a1 g1))) bd ihbd : Π(g1 : Ctx). Π(a1 : Ty). Π(b1 : Ty). Π(bd : Expr (ext a1 g1) b1). Id (Expr (ext a1 g1) b1) (sub_open (ext a1 g1) b1 bd (ext a1 g1) (id_env (ext a1 g1))) bd → Id (Expr g1 (TFn a1 b1)) (sub_open g1 (TFn a1 b1) (ELam g1 a1 b1 bd) g1 (id_env g1)) (ELam g1 a1 b1 bd)) (\g1. \a1. \b1. \f. \ihf. \x. \ihx. ap2 (Expr g1 (TFn a1 b1)) (Expr g1 a1) (Expr g1 b1) (EApp g1 a1 b1) (sub_open g1 (TFn a1 b1) f g1 (id_env g1)) f (sub_open g1 a1 x g1 (id_env g1)) x ihf ihx : Π(g1 : Ctx). Π(a1 : Ty). Π(b1 : Ty). Π(f : Expr g1 (TFn a1 b1)). Id (Expr g1 (TFn a1 b1)) (sub_open g1 (TFn a1 b1) f g1 (id_env g1)) f → Π(x : Expr g1 a1). Id (Expr g1 a1) (sub_open g1 a1 x g1 (id_env g1)) x → Id (Expr g1 b1) (sub_open g1 b1 (EApp g1 a1 b1 f x) g1 (id_env g1)) (EApp g1 a1 b1 f x)) (\g1. \a1. \b1. \val. \ihv. \bd. \ihbd. ap2 (Expr g1 a1) (Expr (ext a1 g1) b1) (Expr g1 b1) (ELet g1 a1 b1) (sub_open g1 a1 val g1 (id_env g1)) val (sub_open (ext a1 g1) b1 bd (ext a1 g1) (id_env (ext a1 g1))) bd ihv ihbd : Π(g1 : Ctx). Π(a1 : Ty). Π(b1 : Ty). Π(val : Expr g1 a1). Id (Expr g1 a1) (sub_open g1 a1 val g1 (id_env g1)) val → Π(bd : Expr (ext a1 g1) b1). Id (Expr (ext a1 g1) b1) (sub_open (ext a1 g1) b1 bd (ext a1 g1) (id_env (ext a1 g1))) bd → Id (Expr g1 b1) (sub_open g1 b1 (ELet g1 a1 b1 val bd) g1 (id_env g1)) (ELet g1 a1 b1 val bd)) (\g1. \t1. \c. \ihc. \th. \ihth. \el. \ihel. ap3 (Expr g1 TBool) (Expr g1 t1) (Expr g1 t1) (Expr g1 t1) (EIf g1 t1) (sub_open g1 TBool c g1 (id_env g1)) c (sub_open g1 t1 th g1 (id_env g1)) th (sub_open g1 t1 el g1 (id_env g1)) el ihc ihth ihel : Π(g1 : Ctx). Π(t1 : Ty). Π(c : Expr g1 TBool). Id (Expr g1 TBool) (sub_open g1 TBool c g1 (id_env g1)) c → Π(th : Expr g1 t1). Id (Expr g1 t1) (sub_open g1 t1 th g1 (id_env g1)) th → Π(el : Expr g1 t1). Id (Expr g1 t1) (sub_open g1 t1 el g1 (id_env g1)) el → Id (Expr g1 t1) (sub_open g1 t1 (EIf g1 t1 c th el) g1 (id_env g1)) (EIf g1 t1 c th el)) e : Π(g : Ctx). Π(t : Ty). Π(e : Expr g t). Id (Expr g t) (sub_open g t e g (id_env g)) e)
:i idsub

-- ground instance: sub_ground empty t X star = X  (id_env empty = star definitionally).
:let idsub_ground = (\t. \X. idsub empty t X : Π(t : Ty). Π(X : Expr empty t). Id (Expr empty t) (sub_ground empty t X star) X)
:i idsub_ground

-- comp_weaken_cancel: composing (ext a empty ⇒ empty by [w]) after weakening cancels.
--   comp (ext a empty) empty (w,star) g (weaken_semctx_d a empty g env) = env
-- empty case: Unit-eta (unitrec).  succ case: head via GenCancel@0 + idsub_ground, tail via IH.
-- This is the env-equality (second component) at the heart of the RT_Lam fusion.
:let comp_weaken_cancel = (\a. \w. \g. indrec Ctx (\g1. Π(env : SemCtx_d empty g1). Id (SemCtx_d empty g1) (comp (ext a empty) empty (w, star) g1 (weaken_semctx_d a empty g1 env)) env : Ctx → Type) (\env. unitrec (\u. Id (SemCtx_d empty empty) star u : SemCtx_d empty empty → Type) (refl star) env : Π(env : SemCtx_d empty empty). Id (SemCtx_d empty empty) (comp (ext a empty) empty (w, star) empty (weaken_semctx_d a empty empty env)) env) (\s. \g1. \ih. \env. ap2 (Expr empty s) (SemCtx_d empty g1) (SemCtx_d empty (ext s g1)) (\p. \q. (p, q)) (sub_open (ext a empty) s (wk0 a empty s (fst env)) empty (w, star)) (fst env) (comp (ext a empty) empty (w, star) g1 (weaken_semctx_d a empty g1 (snd env))) (snd env) (trans (Expr empty s) (sub_open (ext a empty) s (wk0 a empty s (fst env)) empty (w, star)) (sub_open empty s (fst env) empty star) (fst env) (GenCancel a empty s (fst env) zero empty (w, star)) (idsub_ground s (fst env))) (ih (snd env)) : Π(s : Ty). Π(g1 : Ctx). (Π(env : SemCtx_d empty g1). Id (SemCtx_d empty g1) (comp (ext a empty) empty (w, star) g1 (weaken_semctx_d a empty g1 env)) env) → Π(env : SemCtx_d empty (ext s g1)). Id (SemCtx_d empty (ext s g1)) (comp (ext a empty) empty (w, star) (ext s g1) (weaken_semctx_d a empty (ext s g1) env)) env) g : Π(a : Ty). Π(w : Expr empty a). Π(g : Ctx). Π(env : SemCtx_d empty g). Id (SemCtx_d empty g) (comp (ext a empty) empty (w, star) g (weaken_semctx_d a empty g env)) env)
:i comp_weaken_cancel

-- ── GSW tower, layer 1: generalised weakening at a cutoff ──────────────────────
-- weaken_semctx_d_n: env weakening that inserts a fresh binder at cutoff n in the
--   TARGET.  env : SemCtx_d d g  ↦  SemCtx_d (ins a n d) g, each entry Y ↦ wk a d _ Y n.
--   (n = 0 recovers weaken_semctx_d.)  Needed because GSW's binder case fires the IH at
--   (succ n) — the plain n = 0 form is too weak.
:let weaken_semctx_d_n = (\a. \d. \n. \g. indrec Ctx (\g1. SemCtx_d d g1 → SemCtx_d (ins a n d) g1 : Ctx → Type) (\e. star : SemCtx_d d empty → SemCtx_d (ins a n d) empty) (\s. \g1. \ih. \e. (wk a d s (fst e) n, ih (snd e)) : Π(s : Ty). Π(g1 : Ctx). (SemCtx_d d g1 → SemCtx_d (ins a n d) g1) → SemCtx_d d (ext s g1) → SemCtx_d (ins a n d) (ext s g1)) g : Π(a : Ty). Π(d : Ctx). Π(n : Nat). Π(g : Ctx). SemCtx_d d g → SemCtx_d (ins a n d) g)
:i weaken_semctx_d_n

-- wk_lookup_n: lookup commutes with generalised env weakening.  here = refl, there = IH.
--   (Cutoff-generalised wk_lookup.)
:let wk_lookup_n = (\a. \g. \t. \v. indrec Var (\g1. \t1. \v1. Π(n : Nat). Π(d : Ctx). Π(env : SemCtx_d d g1). Id (Expr (ins a n d) t1) (sem_lookup_d (ins a n d) g1 t1 v1 (weaken_semctx_d_n a d n g1 env)) (wk a d t1 (sem_lookup_d d g1 t1 v1 env) n) : Π(g1 : Ctx). Π(t1 : Ty). Var g1 t1 → Type) (\g1. \t1. \n. \d. \env. refl (wk a d t1 (fst env) n) : Π(g1 : Ctx). Π(t1 : Ty). Π(n : Nat). Π(d : Ctx). Π(env : SemCtx_d d (ext t1 g1)). Id (Expr (ins a n d) t1) (sem_lookup_d (ins a n d) (ext t1 g1) t1 (here g1 t1) (weaken_semctx_d_n a d n (ext t1 g1) env)) (wk a d t1 (sem_lookup_d d (ext t1 g1) t1 (here g1 t1) env) n)) (\g1. \t1. \s. \v1. \ih. \n. \d. \env. ih n d (snd env) : Π(g1 : Ctx). Π(t1 : Ty). Π(s : Ty). Π(v1 : Var g1 t1). (Π(n : Nat). Π(d : Ctx). Π(env : SemCtx_d d g1). Id (Expr (ins a n d) t1) (sem_lookup_d (ins a n d) g1 t1 v1 (weaken_semctx_d_n a d n g1 env)) (wk a d t1 (sem_lookup_d d g1 t1 v1 env) n)) → Π(n : Nat). Π(d : Ctx). Π(env : SemCtx_d d (ext s g1)). Id (Expr (ins a n d) t1) (sem_lookup_d (ins a n d) (ext s g1) t1 (there g1 t1 s v1) (weaken_semctx_d_n a d n (ext s g1) env)) (wk a d t1 (sem_lookup_d d (ext s g1) t1 (there g1 t1 s v1) env) n)) v : Π(a : Ty). Π(g : Ctx). Π(t : Ty). Π(v : Var g t). Π(n : Nat). Π(d : Ctx). Π(env : SemCtx_d d g). Id (Expr (ins a n d) t) (sem_lookup_d (ins a n d) g t v (weaken_semctx_d_n a d n g env)) (wk a d t (sem_lookup_d d g t v env) n))
:i wk_lookup_n

-- ── GSW tower, layer 2: the exchange toolkit (ins_ins + transport) ────────────
-- The wk_wk weaken/weaken exchange (the leaf that GSW's binder case needs)
-- bottoms out on ins_ins, the context-exchange law, worked "under coercion"
-- (a trC transport along ins_ins whose type the two sides live in).  This block
-- lands the equality infrastructure: add, sym, trC, ins_ins itself, and the
-- per-constructor transport-commutation microlemmas.  All J one-liners except
-- ins_ins (natrec + indrec Ctx).  RATIFIED with Set 2026-07-16: ins's junk case
-- is a NO-OP (see the ins definition above), which is what makes ins_ins hold
-- unconditionally — no in-range bound, no Empty plumbing.

-- add: recurse on first arg.  add zero n ≡ n, add (succ m) n ≡ succ (add m n).
-- (lark-refine's `plus` is the same function; kept separate to avoid a load-order
-- dependency — this file is checked before lark-refine.)
:let add = (\a. \b. natrec (\_. Nat : Π(_ : Nat). Type) b (\m. \ih. succ ih : Π(m : Nat). Π(_ : Nat). Nat) a : Π(a : Nat). Π(b : Nat). Nat)

-- sym : symmetry of Id (J one-liner; computes to refl on refl).
:let sym = (\A. \x. \y. \p. J A x (\y1. \p1. Id A y1 x : Π(y1 : A). Id A x y1 → Type) (refl x) y p : Π(A : Type). Π(x : A). Π(y : A). Id A x y → Id A y x)

-- trC : transport in a Ctx-indexed family (J; computes to the identity on refl).
-- The workhorse of "under coercion": trC P c1 c2 q carries a P c1 to a P c2
-- along q : Id Ctx c1 c2.  When q reduces to refl the transport vanishes.
:let trC = (\P. \c1. \c2. \q. J Ctx c1 (\c3. \q1. Π(_ : P c1). P c3 : Π(c3 : Ctx). Id Ctx c1 c3 → Type) (\x. x) c2 q : Π(P : Ctx → Type). Π(c1 : Ctx). Π(c2 : Ctx). Id Ctx c1 c2 → P c1 → P c2)

-- ins_ins : the context-EXCHANGE law.  Inserting a2 at the LOWER cutoff i and a1
-- at the HIGHER cutoff (add i n) commute:
--   ins a2 i (ins a1 (add i n) d) = ins a1 (succ (add i n)) (ins a2 i d)
-- By natrec on i (inner indrec Ctx on d):
--   zero        — both sides ≡ ext a2 (ins a1 n d)          (refl)
--   succ, empty — both sides ≡ empty (the no-op junk case)  (refl — REQUIRES
--                 the ratified no-op junk case; the old clamp made this false)
--   succ, ext   — ext s over the goal at (m, g1)            (ap ext ∘ IH)
-- At i = 0 the proof COMPUTES to refl, so the trC coercion built from it
-- vanishes exactly where weaken_n_commute uses it (per-entry at cutoff 0).
:let ins_ins = (\a1. \a2. \n. \i. natrec (\i1. Π(d : Ctx). Id Ctx (ins a2 i1 (ins a1 (add i1 n) d)) (ins a1 (succ (add i1 n)) (ins a2 i1 d)) : Π(i1 : Nat). Type) (\d. refl (ext a2 (ins a1 n d)) : Π(d : Ctx). Id Ctx (ins a2 zero (ins a1 (add zero n) d)) (ins a1 (succ (add zero n)) (ins a2 zero d))) (\m. \ih. \d. indrec Ctx (\d1. Id Ctx (ins a2 (succ m) (ins a1 (add (succ m) n) d1)) (ins a1 (succ (add (succ m) n)) (ins a2 (succ m) d1)) : Ctx → Type) (refl empty : Id Ctx (ins a2 (succ m) (ins a1 (add (succ m) n) empty)) (ins a1 (succ (add (succ m) n)) (ins a2 (succ m) empty))) (\s. \g1. \ihc. ap Ctx Ctx (\c. ext s c) (ins a2 m (ins a1 (add m n) g1)) (ins a1 (succ (add m n)) (ins a2 m g1)) (ih g1) : Π(s : Ty). Π(g1 : Ctx). Π(ihc : Id Ctx (ins a2 (succ m) (ins a1 (add (succ m) n) g1)) (ins a1 (succ (add (succ m) n)) (ins a2 (succ m) g1))). Id Ctx (ins a2 (succ m) (ins a1 (add (succ m) n) (ext s g1))) (ins a1 (succ (add (succ m) n)) (ins a2 (succ m) (ext s g1)))) d : Π(m : Nat). Π(ih : Π(d : Ctx). Id Ctx (ins a2 m (ins a1 (add m n) d)) (ins a1 (succ (add m n)) (ins a2 m d))). Π(d : Ctx). Id Ctx (ins a2 (succ m) (ins a1 (add (succ m) n) d)) (ins a1 (succ (add (succ m) n)) (ins a2 (succ m) d))) i : Π(a1 : Ty). Π(a2 : Ty). Π(n : Nat). Π(i : Nat). Π(d : Ctx). Id Ctx (ins a2 i (ins a1 (add i n) d)) (ins a1 (succ (add i n)) (ins a2 i d)))
:i ins_ins

-- Transport-commutation microlemmas: how trC pushes through each Expr/Var
-- constructor.  All J one-liners with refl bases; binder constructors
-- (there/ELam/ELet) transport the body along ap (ext _) q.  These are the
-- "under coercion" half of the exchange swamp — wk_wk rewrites each side of the
-- goal through the matching micro-lemma before firing ins_ins underneath.
:let tr_here = (\t. \c1. \c2. \q. J Ctx c1 (\c3. \q1. Id (Var (ext t c3) t) (trC (\z. Var z t) (ext t c1) (ext t c3) (ap Ctx Ctx (\z. ext t z) c1 c3 q1) (here c1 t)) (here c3 t) : Π(c3 : Ctx). Id Ctx c1 c3 → Type) (refl (here c1 t)) c2 q : Π(t : Ty). Π(c1 : Ctx). Π(c2 : Ctx). Π(q : Id Ctx c1 c2). Id (Var (ext t c2) t) (trC (\z. Var z t) (ext t c1) (ext t c2) (ap Ctx Ctx (\z. ext t z) c1 c2 q) (here c1 t)) (here c2 t))
:i tr_here

:let tr_there = (\t. \s. \c1. \c2. \q. \w. J Ctx c1 (\c3. \q1. Id (Var (ext s c3) t) (trC (\z. Var z t) (ext s c1) (ext s c3) (ap Ctx Ctx (\z. ext s z) c1 c3 q1) (there c1 t s w)) (there c3 t s (trC (\z. Var z t) c1 c3 q1 w)) : Π(c3 : Ctx). Id Ctx c1 c3 → Type) (refl (there c1 t s w)) c2 q : Π(t : Ty). Π(s : Ty). Π(c1 : Ctx). Π(c2 : Ctx). Π(q : Id Ctx c1 c2). Π(w : Var c1 t). Id (Var (ext s c2) t) (trC (\z. Var z t) (ext s c1) (ext s c2) (ap Ctx Ctx (\z. ext s z) c1 c2 q) (there c1 t s w)) (there c2 t s (trC (\z. Var z t) c1 c2 q w)))
:i tr_there

:let tr_lit_int = (\c1. \c2. \q. \m. J Ctx c1 (\c3. \q1. Id (Expr c3 TInt) (trC (\z. Expr z TInt) c1 c3 q1 (ELitInt c1 m)) (ELitInt c3 m) : Π(c3 : Ctx). Id Ctx c1 c3 → Type) (refl (ELitInt c1 m)) c2 q : Π(c1 : Ctx). Π(c2 : Ctx). Π(q : Id Ctx c1 c2). Π(m : Nat). Id (Expr c2 TInt) (trC (\z. Expr z TInt) c1 c2 q (ELitInt c1 m)) (ELitInt c2 m))
:i tr_lit_int

:let tr_lit_flt = (\c1. \c2. \q. J Ctx c1 (\c3. \q1. Id (Expr c3 TFloat) (trC (\z. Expr z TFloat) c1 c3 q1 (ELitFlt c1)) (ELitFlt c3) : Π(c3 : Ctx). Id Ctx c1 c3 → Type) (refl (ELitFlt c1)) c2 q : Π(c1 : Ctx). Π(c2 : Ctx). Π(q : Id Ctx c1 c2). Id (Expr c2 TFloat) (trC (\z. Expr z TFloat) c1 c2 q (ELitFlt c1)) (ELitFlt c2))
:i tr_lit_flt

:let tr_lit_bool = (\c1. \c2. \q. \b. J Ctx c1 (\c3. \q1. Id (Expr c3 TBool) (trC (\z. Expr z TBool) c1 c3 q1 (ELitBool c1 b)) (ELitBool c3 b) : Π(c3 : Ctx). Id Ctx c1 c3 → Type) (refl (ELitBool c1 b)) c2 q : Π(c1 : Ctx). Π(c2 : Ctx). Π(q : Id Ctx c1 c2). Π(b : Bool). Id (Expr c2 TBool) (trC (\z. Expr z TBool) c1 c2 q (ELitBool c1 b)) (ELitBool c2 b))
:i tr_lit_bool

:let tr_lit_str = (\c1. \c2. \q. J Ctx c1 (\c3. \q1. Id (Expr c3 TStr) (trC (\z. Expr z TStr) c1 c3 q1 (ELitStr c1)) (ELitStr c3) : Π(c3 : Ctx). Id Ctx c1 c3 → Type) (refl (ELitStr c1)) c2 q : Π(c1 : Ctx). Π(c2 : Ctx). Π(q : Id Ctx c1 c2). Id (Expr c2 TStr) (trC (\z. Expr z TStr) c1 c2 q (ELitStr c1)) (ELitStr c2))
:i tr_lit_str

:let tr_unit = (\c1. \c2. \q. J Ctx c1 (\c3. \q1. Id (Expr c3 TUnit) (trC (\z. Expr z TUnit) c1 c3 q1 (EUnit c1)) (EUnit c3) : Π(c3 : Ctx). Id Ctx c1 c3 → Type) (refl (EUnit c1)) c2 q : Π(c1 : Ctx). Π(c2 : Ctx). Π(q : Id Ctx c1 c2). Id (Expr c2 TUnit) (trC (\z. Expr z TUnit) c1 c2 q (EUnit c1)) (EUnit c2))
:i tr_unit

:let tr_evar = (\t. \c1. \c2. \q. \w. J Ctx c1 (\c3. \q1. Id (Expr c3 t) (trC (\z. Expr z t) c1 c3 q1 (EVar c1 t w)) (EVar c3 t (trC (\z. Var z t) c1 c3 q1 w)) : Π(c3 : Ctx). Id Ctx c1 c3 → Type) (refl (EVar c1 t w)) c2 q : Π(t : Ty). Π(c1 : Ctx). Π(c2 : Ctx). Π(q : Id Ctx c1 c2). Π(w : Var c1 t). Id (Expr c2 t) (trC (\z. Expr z t) c1 c2 q (EVar c1 t w)) (EVar c2 t (trC (\z. Var z t) c1 c2 q w)))
:i tr_evar

:let tr_lam = (\A. \B. \c1. \c2. \q. \bd. J Ctx c1 (\c3. \q1. Id (Expr c3 (TFn A B)) (trC (\z. Expr z (TFn A B)) c1 c3 q1 (ELam c1 A B bd)) (ELam c3 A B (trC (\z. Expr z B) (ext A c1) (ext A c3) (ap Ctx Ctx (\z. ext A z) c1 c3 q1) bd)) : Π(c3 : Ctx). Id Ctx c1 c3 → Type) (refl (ELam c1 A B bd)) c2 q : Π(A : Ty). Π(B : Ty). Π(c1 : Ctx). Π(c2 : Ctx). Π(q : Id Ctx c1 c2). Π(bd : Expr (ext A c1) B). Id (Expr c2 (TFn A B)) (trC (\z. Expr z (TFn A B)) c1 c2 q (ELam c1 A B bd)) (ELam c2 A B (trC (\z. Expr z B) (ext A c1) (ext A c2) (ap Ctx Ctx (\z. ext A z) c1 c2 q) bd)))
:i tr_lam

:let tr_app = (\A. \B. \c1. \c2. \q. \F. \X. J Ctx c1 (\c3. \q1. Id (Expr c3 B) (trC (\z. Expr z B) c1 c3 q1 (EApp c1 A B F X)) (EApp c3 A B (trC (\z. Expr z (TFn A B)) c1 c3 q1 F) (trC (\z. Expr z A) c1 c3 q1 X)) : Π(c3 : Ctx). Id Ctx c1 c3 → Type) (refl (EApp c1 A B F X)) c2 q : Π(A : Ty). Π(B : Ty). Π(c1 : Ctx). Π(c2 : Ctx). Π(q : Id Ctx c1 c2). Π(F : Expr c1 (TFn A B)). Π(X : Expr c1 A). Id (Expr c2 B) (trC (\z. Expr z B) c1 c2 q (EApp c1 A B F X)) (EApp c2 A B (trC (\z. Expr z (TFn A B)) c1 c2 q F) (trC (\z. Expr z A) c1 c2 q X)))
:i tr_app

