(* Test 04 — Tail-recursive accumulator
   Covers: tail calls (must not stack-overflow at 1,000,000 iterations),
           accumulator pattern, defined Int overflow.
   Int is a wrapping 32-bit two's-complement integer in every backend,
   so sum_to(1000000) = 500000500000 mod 2^32 = 1784293664 — everywhere.
   Expected output:
     1784293664 *)

module TailRec

fn sum_to(n : Int, acc : Int) : Int =
  if n == 0 then acc
  else sum_to(n - 1, acc + n)

fn main(io : IO) : IO =
  print(io, show(sum_to(1000000, 0)))
