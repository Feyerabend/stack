(* Test 09 — Module import and export
   Covers: import with exposing, using exported types and functions,
           pi stays private to Shapes (not re-exported)
   Expected output:
     78.53975
     31.4159
     12.0 *)

module Main

import Shapes exposing (Shape, area, perimeter)

fn main(io : IO) : IO =
  let c  = Circle(5.0) in
  let r  = Rect(3.0, 4.0) in
  let io = print(io, show(area(c))) in
  let io = print(io, show(perimeter(c))) in
  print(io, show(area(r)))
