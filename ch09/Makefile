.PHONY: all run run-passes run-riscv clean

PYTHON := python3

# Chapter 9 — Code Generation.
# `make run` runs every section's companion: the §9.2-§9.6 Python demos (each a
# self-contained, no-argument script) plus the two §9.4 RISC-V toolchains, which
# have their own Makefiles. The 02 toolchain's sample programs are generated by
# its setup.sh, so `run-riscv` runs that first.

# §9.2-§9.6 and the supplementary JIT — one self-demoing script each.
PASSES := \
  02_instruction_selection/isel.py \
  03_register_allocation/regalloc.py \
  05_the_6502/codegen6502.py \
  06_tail_calls/tail.py \
  06_tail_calls/general.py \
  jit/hotspot.py

all: run

run: run-passes run-riscv

run-passes:
	@for f in $(PASSES); do echo "== $$f =="; $(PYTHON) $$f || exit 1; echo; done

run-riscv:
	@echo "== 04_riscv/01: assemble + run fact, fib, array =="
	@$(MAKE) -C 04_riscv/01 --no-print-directory run-all
	@echo "== 04_riscv/02: setup, assemble, link, run, test =="
	@cd 04_riscv/02 && sh setup.sh >/dev/null && $(MAKE) --no-print-directory all && $(PYTHON) test.py

clean:
	@$(MAKE) -C 04_riscv/01 --no-print-directory clean 2>/dev/null || true
	@$(MAKE) -C 04_riscv/02 --no-print-directory clean 2>/dev/null || true
	@rm -rf 04_riscv/01/bin 04_riscv/02/build 04_riscv/02/samples
	@find . -name __pycache__ -type d -exec rm -rf {} + 2>/dev/null || true
	@find . -name '*.dSYM' -type d -exec rm -rf {} + 2>/dev/null || true
	@find . -name '.DS_Store' -delete 2>/dev/null || true
	@echo "ch09 clean."
